}

@media (max-width: 430px) {
  .services-page {
    width: 100%;
    margin: 0;
  }

  .services-hero {
    border-radius: 0;
    border-left: none;
    border-right: none;
  }

  .services-hero-text h1 {
    font-size: 30px;
  }

  .services-hero-image {
    width: 250px;
  }

  .services-primary-icon {
    width: 64px;
    height: 64px;
    margin-left: -16px;
    margin-right: -14px;
  }

  .services-secondary-icon {
    width: 68px;
