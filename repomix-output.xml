<file path="frontend/src/pages/Login/Login.css">
* {
  box-sizing: border-box;
}

.login-page-wrapper {
  width: 100%;
  min-height: 100vh;
  background: #fff6ec;
  font-family: "Segoe UI", Arial, sans-serif;
  color: #20253a;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-page {
  width: calc(100% - 64px);
  max-width: 1220px;
  margin: 24px auto 34px;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 620px;
}

/* Card principal */

.login-card {
  width: 100%;
  max-width: 470px;
  background: rgba(255, 255, 255, 0.94);
  border: 1.5px solid #eadfd3;
  border-radius: 24px;
  box-shadow: 0 18px 45px rgba(146, 116, 78, 0.12);
  padding: 42px 42px 36px;
}

.login-card-header {
  text-align: center;
  margin-bottom: 30px;
}

.login-card-header h1 {
  margin: 0 0 12px;
  color: #20253a;
  font-size: 34px;
  font-weight: 900;
  line-height: 1.1;
}

.login-card-header p {
  margin: 0 auto;
  max-width: 370px;
  color: #50566d;
  font-size: 15.5px;
  line-height: 1.5;
  font-weight: 500;
}

/* Formulario */

.login-form {
  width: 100%;
}

.login-form-group {
  width: 100%;
  margin-bottom: 18px;
}

.login-form-group label {
  display: block;
  margin-bottom: 8px;
  color: #20253a;
  font-size: 14.5px;
  font-weight: 800;
}

.login-form-group input {
  width: 100%;
  height: 50px;
  border: 1.5px solid #eadfd3;
  border-radius: 14px;
  background: #ffffff;
  color: #20253a;
  font-family: inherit;
  font-size: 15px;
  font-weight: 500;
  padding: 0 16px;
  outline: none;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.login-form-group input::placeholder {
  color: #9ba0ad;
}

.login-form-group input:focus {
  border-color: #7ab35a;
  box-shadow: 0 0 0 4px rgba(122, 179, 90, 0.14);
}

/* Mensaje de error */

.login-error-message {
  margin: -6px 0 18px;
  color: #d94b4b;
  background: #fff0f0;
  border: 1.5px solid #ffd1d1;
  border-radius: 12px;
  padding: 10px 14px;
  font-size: 13.5px;
  font-weight: 700;
  line-height: 1.4;
}

/* Opciones */

.login-options {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  margin: 4px 0 24px;
}

.login-remember {
  display: flex;
  align-items: center;
  gap: 8px;
  color: #50566d;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
}

.login-remember input {
  width: 16px;
  height: 16px;
  accent-color: #6fa04f;
  cursor: pointer;
}

.login-forgot-button {
  border: none;
  background: transparent;
  color: #6fa04f;
  font-family: inherit;
  font-size: 14px;
  font-weight: 800;
  cursor: pointer;
  padding: 0;
}

.login-forgot-button:hover {
  text-decoration: underline;
}

/* Botón iniciar sesión */

.login-submit-button {
  width: 100%;
  height: 52px;
  border: none;
  border-radius: 14px;
  background: linear-gradient(135deg, #76ad50, #5f9b3b);
  color: #ffffff;
  font-family: inherit;
  font-size: 16px;
  font-weight: 900;
  cursor: pointer;
  box-shadow: 0 14px 26px rgba(111, 160, 79, 0.28);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.login-submit-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 18px 32px rgba(111, 160, 79, 0.34);
}

/* Registro */

.login-register-text {
  margin-top: 24px;
  text-align: center;
}

.login-register-text p {
  margin: 0;
  color: #50566d;
  font-size: 14.5px;
  font-weight: 600;
}

.login-register-text button {
  border: none;
  background: transparent;
  color: #6fa04f;
  font-family: inherit;
  font-size: 14.5px;
  font-weight: 900;
  cursor: pointer;
  padding: 0;
}

.login-register-text button:hover {
  text-decoration: underline;
}

/* Redes sociales */

.login-social-section {
  margin-top: 26px;
}

.login-divider {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 14px;
  margin-bottom: 22px;
}

.login-divider span {
  height: 1px;
  background: #eadfd3;
}

.login-divider p {
  margin: 0;
  color: #a2a0a0;
  font-size: 13.5px;
  font-weight: 500;
  white-space: nowrap;
}

.login-social-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.login-social-button {
  height: 54px;
  border: 1.5px solid #eadfd3;
  border-radius: 14px;
  background: #ffffff;
  color: #20253a;
  font-family: inherit;
  font-size: 15px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2px;
  cursor: pointer;
  box-shadow: 0 8px 20px rgba(146, 116, 78, 0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  overflow: visible;
  text-align: center;
  padding: 0;
}

.login-social-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 24px rgba(146, 116, 78, 0.1);
}

/* Ajuste interno para Google */

.login-social-button:first-child {
  transform: none;
  padding-left: 0;
  padding-right: 10px;
}

.login-social-button:first-child:hover {
  transform: translateY(-2px);
}

/* Ajuste interno para Facebook */

.login-social-button:nth-child(2) {
  transform: none;
  padding-left: 0;
  padding-right: 10px;
}

.login-social-button:nth-child(2):hover {
  transform: translateY(-2px);
}

/* Imágenes sociales */

.login-social-icon {
  width: 42px;
  height: 42px;
  object-fit: contain;
  display: block;
  flex-shrink: 0;
  margin: 0;
  transform-origin: center;
}

.google-social-icon {
  transform: translateY(2px) translateX(0px) scale(2.6);
}

.face-social-icon {
  transform: translateY(2px) translateX(0px) scale(2.6);
}

/* Responsive */

@media (max-width: 760px) {
  .login-page {
    width: calc(100% - 32px);
    min-height: 560px;
    margin: 20px auto 30px;
  }

  .login-card {
    max-width: 100%;
    padding: 36px 28px 32px;
    border-radius: 22px;
  }

  .login-card-header h1 {
    font-size: 30px;
  }

  .login-options {
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  .login-social-button:first-child {
    transform: none;
    padding-left: 0;
    padding-right: 8px;
  }

  .login-social-button:first-child:hover {
    transform: translateY(-2px);
  }

  .login-social-button:nth-child(2) {
    transform: none;
    padding-left: 0;
    padding-right: 8px;
  }

  .login-social-button:nth-child(2):hover {
    transform: translateY(-2px);
  }

  .login-social-icon {
    width: 40px;
    height: 40px;
  }

  .google-social-icon {
    transform: translateY(2px) translateX(0px) scale(2.3);
  }

  .face-social-icon {
    transform: translateY(2px) translateX(0px) scale(2.3);
  }
}

@media (max-width: 430px) {
  .login-page {
    width: calc(100% - 24px);
    margin: 16px auto 26px;
  }

  .login-card {
    padding: 34px 22px 30px;
  }

  .login-card-header h1 {
    font-size: 28px;
  }

  .login-card-header p {
    font-size: 14.5px;
  }

  .login-form-group input {
    height: 48px;
  }

  .login-submit-button {
    height: 50px;
  }

  .login-social-buttons {
    grid-template-columns: 1fr;
  }

  .login-social-button:first-child {
    transform: none;
    padding-left: 0;
    padding-right: 6px;
  }

  .login-social-button:first-child:hover {
    transform: translateY(-2px);
  }

  .login-social-button:nth-child(2) {
    transform: none;
    padding-left: 0;
    padding-right: 6px;
  }

  .login-social-button:nth-child(2):hover {
    transform: translateY(-2px);
  }

  .login-social-icon {
    width: 38px;
    height: 38px;
  }

  .google-social-icon {
    transform: translateY(2px) translateX(0px) scale(2.1);
  }

  .face-social-icon {
    transform: translateY(2px) translateX(0px) scale(2.1);
  }
}
