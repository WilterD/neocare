                    </span>
                  ))
                ) : (
                  <span className={`result-chip ${riskLevel}`}>
                    {emptySummaryText}
                  </span>
                )}
              </div>
            </div>
          </section>

          <section className={`result-card result-action-card ${riskLevel}`}>
            <div className="result-action-text">
