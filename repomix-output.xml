  border: 1.5px solid #ece2d4;
  border-radius: 18px;
  padding: 16px 22px;
  margin-bottom: 18px;
  box-shadow: 0 8px 22px rgba(146, 116, 78, 0.08);
}

.edu-vac-hero-label {
  color: #6fa04f;
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.edu-vac-hero h1 {
  margin: 4px 0 8px;
  color: #343349;
  font-size: 24px;
  font-weight: 850;
  letter-spacing: -0.5px;
}

.edu-vac-hero p {
  margin: 0 0 10px;
  color: #343349;
  font-size: 13px;
  line-height: 1.45;
}

.edu-vac-hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
}

.edu-vac-tag {
