  gap: 12px;
  padding-top: 8px;
  margin-top: 0;
  border-top: 1px solid #eadfd3;
}

/* CTA */

.about-cta-section {
  width: 100%;
  max-width: 1080px;
  min-height: 150px;
  margin: 0 auto;
  background: linear-gradient(135deg, #f5f7e7 0%, #f9f3df 100%);
  border: 1.5px solid #eadfd3;
  border-radius: 22px;
  display: block;
  padding: 28px 36px;
  overflow: hidden;
  position: relative;
  box-shadow: 0 14px 32px rgba(146, 116, 78, 0.08);
}

.about-cta-content {
  width: 100%;
}

.about-cta-content h2 {
  margin: 0 0 8px;
  color: #1f1f24;
  font-size: 26px;
  font-weight: 850;
}

.about-cta-content p {
  max-width: 780px;
  margin: 0 0 18px;
  color: #343349;
  font-size: 14.2px;
  font-weight: 500;
  line-height: 1.55;
}

.about-cta-button {
  height: 48px;
  border: none;
  border-radius: 11px;
  background: linear-gradient(135deg, #8ab86c, #6fa04f);
  color: #ffffff;
  font-family: inherit;
  font-size: 14px;
  font-weight: 850;
  padding: 0 24px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  cursor: pointer;
  box-shadow: 0 12px 24px rgba(111, 160, 79, 0.25);
  overflow: visible;
  transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
}

.about-cta-button:hover {
  transform: translateY(-4px);
  box-shadow: 0 18px 32px rgba(111, 160, 79, 0.32);
  background: linear-gradient(135deg, #94c275, #6fa04f);
}

.about-cta-button:active {
  transform: translateY(-1px);
}

.about-cta-icon-box {
  width: 24px;
  height: 24px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: visible;
}

.about-cta-button-icon {
  width: 24px;
  height: 24px;
  object-fit: contain;
  display: block;
  flex-shrink: 0;
  transform: scale(4);
  transform-origin: center;
}

.about-cta-button-label {
  display: inline-flex;
  align-items: center;
  color: #ffffff;
  line-height: 1;
}

.about-cta-button strong {
  font-size: 18px;
  line-height: 1;
}

/* Footer */

.about-page-wrapper .app-footer {
  width: 100%;
  margin-top: 0;
}

/* Responsive */

@media (max-width: 1100px) {
  .about-page {
    padding: 24px 26px 32px;
  }

  .about-hero-section {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .about-hero-text {
    max-width: 760px;
    margin: 0 auto;
  }

  .about-hero-image-box {
    height: 350px;
  }

  .about-hero-image {
    max-width: 500px;
  }

  .about-info-grid {
    grid-template-columns: 1fr;
    max-width: 720px;
  }

  .about-info-card {
