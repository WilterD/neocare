  }

  .about-hero-section {
    min-height: auto;
  }

  .about-hero-text h1 {
    font-size: 32px;
  }

  .about-hero-text > p:not(.about-eyebrow) {
    font-size: 15px;
  }

  .about-hero-image-box {
    height: 280px;
  }

  .about-info-card {
    grid-template-columns: 1fr;
    text-align: center;
    padding: 28px 24px;
  }

  .about-card-icon {
    margin: 0 auto;
  }

  .about-guide-card {
    grid-template-columns: 1fr;
  }

  .about-guide-item {
    border-right: none;
  }

  .about-team-section {
    max-width: 100%;
  }

  .about-team-content {
    padding: 20px 24px 20px;
  }

  .about-team-list {
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .about-team-member,
  .about-team-member.professor {
    grid-template-columns: 58px 1fr;
  }

  .about-team-user-icon,
  .about-team-user-icon.professor-icon {
    width: 54px;
