    transform: translateY(1px);
  }

  .services-secondary-btn {
    min-width: unset;
    height: 40px;
  }

  .services-secondary-icon {
    width: 76px;
    height: 76px;
    margin-left: -18px;
    margin-right: -18px;
    transform: translateY(2px);
  }

  .services-safe-note {
    margin-top: 4px;
    align-items: center;
  }

  .services-safe-icon {
    width: 46px;
    height: 46px;
    margin-left: -10px;
    margin-right: -10px;
    transform: translateY(0);
  }

  .services-grid {
    grid-template-columns: 1fr;
  }

  .service-card {
    grid-template-columns: 86px 1fr;
    align-items: center;
    padding: 22px 20px;
  }

  .service-image-box {
    width: 86px;
    min-height: 110px;
  }

  .service-card-image {
    width: 86px;
    height: 86px;
    transform: scale(1.35);
  }

  .services-trust-bar {
    grid-template-columns: 1fr;
    padding: 22px;
  }

  .services-trust-bar article {
    grid-template-columns: 42px 1fr;
    gap: 4px;
    overflow: visible;
  }

  .services-trust-icon {
    width: 50px;
    height: 50px;
    max-width: 50px;
    max-height: 50px;
    transform: translateX(3px) scale(2);
