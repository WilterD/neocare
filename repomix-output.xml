  .register-form-section,
  .option-group,
  .consent-card {
    border-radius: 14px;
    padding: 14px;
  }

  .register-actions {
    flex-direction: column;
  }

  .btn-primary,
  .btn-secondary {
    width: 100%;
  }
}
