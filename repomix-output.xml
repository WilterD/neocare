}

.edu-vac-intro-card,
.edu-vac-vacunas-card,
.edu-vac-controles-card,
.edu-vac-crecimiento-card,
.edu-vac-consejos-card,
.edu-vac-recordatorio-card {
  background: #ffffff;
  border: 1.5px solid #ece2d4;
  border-radius: 18px;
  padding: 22px 24px;
  margin-bottom: 18px;
  box-shadow: 0 8px 22px rgba(146, 116, 78, 0.08);
}

.edu-vac-intro-card h3,
.edu-vac-vacunas-card h3,
.edu-vac-controles-card h3,
.edu-vac-crecimiento-card h3,
.edu-vac-consejos-card h3 {
  margin: 0 0 12px;
  color: #343349;
  font-size: 18px;
  font-weight: 800;
}

.edu-vac-intro-card p {
  color: #343349;
  font-size: 14px;
  line-height: 1.5;
  margin: 0 0 10px;
}

.edu-vac-subtitle {
  color: #6b6b7c;
  font-size: 13px;
  margin: 0 0 14px;
}

.edu-vac-section-title {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 4px;
}

.edu-vac-section-title img {
  width: 32px;
  height: 32px;
  object-fit: contain;
}

.edu-vac-vacunas-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 10px;
  margin-top: 8px;
}

.edu-vac-vacuna {
  background: #fffaf2;
  border: 1.5px solid #ece2d4;
  border-left: 4px solid #6fa04f;
  border-radius: 12px;
  padding: 10px 14px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.edu-vac-vacuna-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.edu-vac-vacuna-head strong {
  color: #343349;
  font-size: 14px;
  font-weight: 800;
}

.edu-vac-vacuna-dosis {
  background: #6fa04f;
  color: #ffffff;
  font-size: 11px;
  font-weight: 800;
  padding: 2px 10px;
  border-radius: 999px;
}

.edu-vac-vacuna-momento {
  display: flex;
  align-items: center;
  gap: 6px;
  color: #343349;
  font-size: 12.5px;
  font-weight: 600;
}

.edu-vac-vacuna-icono {
  color: #6fa04f;
  font-size: 14px;
}

.edu-vac-vacuna-previene {
  background: #ffffff;
  border: 1px dashed #ece2d4;
  border-radius: 8px;
  padding: 6px 10px;
  color: #343349;
  font-size: 12px;
  line-height: 1.4;
}

.edu-vac-vacuna-label {
  display: inline-block;
  font-size: 10px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: #6fa04f;
  margin-right: 4px;
}

.edu-vac-controles-linea {
  margin-top: 8px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  position: relative;
}

.edu-vac-controles-linea::before {
  content: "";
  position: absolute;
  left: 22px;
  top: 16px;
  bottom: 16px;
  width: 2px;
  background: linear-gradient(180deg, #6fa04f 0%, #54813a 100%);
  z-index: 0;
}

.edu-vac-control {
  position: relative;
  display: grid;
  grid-template-columns: 50px 1fr;
  gap: 12px;
  align-items: center;
  background: #fffaf2;
  border: 1.5px solid #ece2d4;
  border-radius: 12px;
  padding: 10px 14px;
  z-index: 1;
}

.edu-vac-control-punto {
  display: flex;
  align-items: center;
  justify-content: center;
}

.edu-vac-control-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: #ffffff;
  border: 3px solid #6fa04f;
  color: #2f6b1d;
  font-size: 14px;
  font-weight: 800;
  border-radius: 50%;
}

.edu-vac-control-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.edu-vac-control-edad {
  color: #6fa04f;
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.edu-vac-control-info strong {
  color: #343349;
  font-size: 14px;
  font-weight: 800;
}

.edu-vac-control-info p {
  margin: 2px 0 0;
  color: #6b6b7c;
  font-size: 12.5px;
  line-height: 1.4;
}

.edu-vac-medidas-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin: 12px 0;
}

.edu-vac-medida {
  background: #fffaf2;
  border: 1.5px solid #ece2d4;
  border-radius: 12px;
  padding: 12px 14px;
}

.edu-vac-medida strong {
  display: block;
  color: #343349;
  font-size: 14px;
  font-weight: 800;
  margin-bottom: 6px;
}

.edu-vac-medida p {
  margin: 0;
  color: #6b6b7c;
  font-size: 12.5px;
  line-height: 1.45;
}

.edu-vac-crecimiento-nota {
  margin: 0;
  background: rgba(111, 160, 79, 0.08);
  border-left: 3px solid #6fa04f;
  border-radius: 6px;
  padding: 10px 14px;
  color: #343349;
  font-size: 13px;
  line-height: 1.5;
}

.edu-vac-consejos-list {
  list-style: none;
  margin: 8px 0 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
}

.edu-vac-consejos-list li {
  position: relative;
  padding: 10px 14px 10px 38px;
  background: #fffaf2;
  border: 1.5px solid #ece2d4;
  border-left: 4px solid #6fa04f;
  border-radius: 10px;
  color: #343349;
  font-size: 13px;
  line-height: 1.45;
}

.edu-vac-consejos-list li::before {
  content: "✓";
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  width: 22px;
  height: 22px;
  background: #6fa04f;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 800;
}

.edu-vac-recordatorio-card {
  display: grid;
  grid-template-columns: 80px 1fr;
  gap: 16px;
  align-items: center;
  background: rgba(111, 160, 79, 0.1);
  border: 1.5px solid rgba(111, 160, 79, 0.3);
}

.edu-vac-recordatorio-card img {
  width: 80px;
  height: 80px;
  object-fit: contain;
}

.edu-vac-recordatorio-card h3 {
  margin: 0 0 6px;
  color: #2f6b1d;
  font-size: 16px;
  font-weight: 800;
}

.edu-vac-recordatorio-card p {
  margin: 0 0 12px;
  color: #343349;
  font-size: 13px;
  line-height: 1.5;
}

.edu-vac-recordatorio-button {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border: none;
  background: linear-gradient(135deg, #6fa04f 0%, #54813a 100%);
  color: #ffffff;
  font-family: inherit;
  font-size: 13px;
  font-weight: 800;
  padding: 9px 18px;
  border-radius: 999px;
  cursor: pointer;
}

.edu-vac-recordatorio-button:hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 16px rgba(84, 129, 58, 0.22);
}

.edu-vac-recordatorio-button span {
  font-size: 18px;
  line-height: 1;
}

@media (max-width: 1050px) {
  .edu-vac-desktop {
    grid-template-columns: 1fr;
  }

  .edu-vac-hero {
    grid-template-columns: 1fr;
  }

  .edu-vac-hero-image-box img {
    width: 110px;
    height: 110px;
  }

  .edu-vac-medidas-grid,
  .edu-vac-consejos-list {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 760px) {
  .edu-vac-desktop {
    width: 100%;
    margin-top: 0;
    border-radius: 0;
    border-left: none;
    border-right: none;
  }

  .edu-vac-main-panel {
    padding: 26px 18px;
  }
}
