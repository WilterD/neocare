<file path="frontend/src/pages/Evaluation/Evaluation.css">
* {
  box-sizing: border-box;
}

.evaluation-page-wrapper {
  width: 100%;
  min-height: 100vh;
  background: #fff6ec;
  font-family: "Segoe UI", Arial, sans-serif;
  color: #343349;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Contenedor principal */

.evaluation-desktop {
  width: calc(100% - 44px);
  max-width: 1180px;
  min-height: 700px;
  margin-top: 10px;
  margin-bottom: 28px;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
  border: 1px solid #eee7df;
  border-radius: 8px;
  display: grid;
  grid-template-columns: 185px 1fr;
  overflow: hidden;
  box-shadow: 0 16px 48px rgba(146, 116, 78, 0.12);
}

/* Sidebar */

.evaluation-sidebar {
  position: relative;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
  border-right: 1px solid #eadfd3;
  padding: 42px 14px 24px;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.evaluation-sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.evaluation-sidebar-item {
  width: 100%;
  height: 50px;
  border: none;
  border-radius: 16px;
  background: transparent;
  color: #343349;
  font-family: inherit;
  font-size: 15px;
  font-weight: 700;
  display: grid;
  grid-template-columns: 46px 1fr;
  align-items: center;
  text-align: left;
  padding: 0 12px;
  cursor: pointer;
  text-decoration: none;
  transition: color 0.2s ease, background 0.2s ease;
}

/* Imágenes del menú lateral */

.evaluation-sidebar-icon-box {
  width: 42px;
  height: 42px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.evaluation-sidebar-icon {
  width: 48px;
  height: 48px;
  object-fit: contain;
  display: block;
  transition: transform 0.2s ease;
}

/* Hover: solo texto e imagen, sin bloque */

.evaluation-sidebar-item:hover {
  color: #6fa04f;
  background: transparent;
}

.evaluation-sidebar-item:hover .evaluation-sidebar-icon {
  transform: scale(1.06);
}

/* Activo: bloque verde solo en la pantalla activa */

.evaluation-sidebar-item.active {
  background: rgba(213, 230, 196, 0.45);
  border: 1.5px solid rgba(111, 160, 79, 0.38);
  color: #6fa04f;
  font-weight: 800;
}

.evaluation-sidebar-item.active .evaluation-sidebar-icon {
  transform: scale(1.08);
}

/* Panel principal */

.evaluation-main-panel {
  padding: 32px 28px 28px;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
}

/* Título */

.evaluation-title-row {
  display: grid;
  grid-template-columns: 1fr 42px;
  align-items: center;
  gap: 14px;
  margin-bottom: 24px;
}

.evaluation-title-row h1 {
  margin: 0;
  color: #343349;
  font-size: 26px;
  font-weight: 850;
  letter-spacing: -0.4px;
}

.evaluation-help-button {
  width: 38px;
  height: 38px;
  justify-self: end;
  border: 3px solid #6fa04f;
  border-radius: 50%;
  background: transparent;
  color: #6fa04f;
  font-family: inherit;
  font-size: 22px;
  font-weight: 850;
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
}

/* Hero */

.evaluation-hero-card {
  min-height: 136px;
  border: 1.5px solid #eadfd3;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.96);
  display: grid;
  grid-template-columns: 180px 1fr;
  align-items: center;
  gap: 16px;
  padding: 16px 24px;
  overflow: hidden;
  position: relative;
  box-shadow: 0 14px 32px rgba(146, 116, 78, 0.08);
}

/* Imagen CT del hero */

.evaluation-hero-image-box {
  width: 180px;
  height: 116px;
  display: flex;
  justify-content: center;
  align-items: center;
  justify-self: center;
  overflow: visible;
}

.evaluation-hero-image {
  width: 250px;
  height: 250px;
  object-fit: contain;
  display: block;
}

.evaluation-hero-text h2 {
  margin: 0 0 10px;
  color: #343349;
  font-size: 22px;
  font-weight: 850;
}

.evaluation-hero-text p {
  margin: 0;
  color: #343349;
  font-size: 15.5px;
