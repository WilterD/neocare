                    <strong>{resultData.neonatalLabel}</strong>
                  </span>
                </div>
              )}

              <h3>{summaryTitle}</h3>

              <div className="result-chip-list">
                {hasIdentifiedItems ? (
                  identifiedItems.map((item, index) => (
                    <span
                      key={item.id || item.label || index}
                      className={`result-chip ${riskLevel}`}
                    >
