  list-style: none;
  counter-reset: edu-seg-counter;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.edu-seg-pasos li {
  position: relative;
  padding: 10px 14px 10px 48px;
  background: #fffaf2;
  border: 1.5px solid #ece2d4;
  border-left: 4px solid #6fa04f;
  border-radius: 10px;
