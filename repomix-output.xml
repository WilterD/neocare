}

.help-contact-button span {
  font-size: 20px;
  line-height: 1;
  transform: translateY(-1px);
}

.help-contact-button:hover {
  background: rgba(213, 230, 196, 0.22);
  transform: translateY(-1px);
}

.register-title-area {
  text-align: left;
}

.register-title-area h1 {
  margin: 4px 0 0;
  color: #343349;
  font-size: 29px;
  font-weight: 800;
}

.register-title-area p {
  margin: 8px 0 0;
  text-align: center;
  color: #343349;
  font-size: 16px;
  font-weight: 700;
}

/* Barra superior */

.top-progress {
  width: calc(100% - 170px);
  margin-left: 100px;
  margin-top: 0;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
}

.top-progress-item {
  display: flex;
  align-items: center;
  flex: 1;
}

.top-progress-item:last-child {
  flex: 0;
}

.top-step {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 3px solid #ded8ce;
  background: #fffaf2;
  color: #8b8985;
  font-size: 17px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: default;
  pointer-events: none;
}

.top-step.active {
  background: #8ab86c;
  border-color: #8ab86c;
  color: #ffffff;
}

.top-line {
  height: 3px;
  flex: 1;
  min-width: 50px;
  background: #ded8ce;
}

.top-line.active {
  background: #8ab86c;
}

/* Layout principal */

.register-main {
  display: grid;
  grid-template-columns: 285px 1fr;
  gap: 18px;
  align-items: stretch;
}

/* Sidebar */

.register-sidebar {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding-top: 0;
}

.register-sidebar::before {
  content: "";
  position: absolute;
  top: 62px;
  bottom: 62px;
  left: 54px;
  border-left: 2px dashed #ddd4c9;
}

.sidebar-step {
  position: relative;
  z-index: 2;
  width: 100%;
  min-height: 84px;
  border: none;
  background: transparent;
  display: grid;
  grid-template-columns: 96px 1fr;
  align-items: center;
  gap: 10px;
  text-align: left;
  cursor: default;
  pointer-events: none;
  padding: 0 6px;
}

.sidebar-step.active {
  background: rgba(213, 230, 196, 0.45);
  border: 1.5px solid rgba(111, 160, 79, 0.38);
  border-radius: 16px;
  padding: 7px;
}

/* Íconos laterales */

.sidebar-icon {
  width: 88px !important;
  height: 88px !important;
  min-width: 88px !important;
  max-width: 88px !important;
  min-height: 88px !important;
  max-height: 88px !important;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: visible;
  background: transparent;
}

.sidebar-icon img {
  width: 88px !important;
  height: 88px !important;
  min-width: 88px !important;
  max-width: 88px !important;
  min-height: 88px !important;
  max-height: 88px !important;
  object-fit: contain !important;
  display: block !important;
  position: static !important;
  transform: none !important;
  margin: 0 !important;
  padding: 0 !important;
}

.sidebar-step img {
  pointer-events: none;
}

.icon-1,
.icon-2,
.icon-3,
.icon-4,
.icon-5,
.icon-6 {
  background: transparent;
  color: inherit;
}

.sidebar-label {
  color: #343349;
  font-size: 14.2px;
  font-weight: 650;
  line-height: 1.3;
}

.sidebar-step.active .sidebar-label {
  color: #6fa04f;
  font-weight: 800;
}

/* Tarjeta principal */

.register-card {
  width: 100%;
  min-height: 470px;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 22px;
  padding: 26px 34px;
  box-shadow: 0 18px 45px rgba(146, 116, 78, 0.14);
  display: grid;
  grid-template-columns: 36% 1fr;
  align-items: center;
  gap: 30px;
}

/* Imagen principal */

.card-illustration {
  width: 100%;
  height: 300px;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}

.register-main-image {
  width: 100%;
  max-width: 260px;
  height: auto;
  object-fit: contain;
  display: block;
}

/* Formulario */

.form-side {
  width: 100%;
}

.register-card-title h2,
.placeholder-step h2,
.option-step h2 {
  margin: 0;
  color: #343349;
  font-size: 23px;
  font-weight: 800;
}

.register-card-title p,
.placeholder-step p,
.option-step > p {
  margin: 8px 0 18px;
  color: #343349;
  font-size: 14.5px;
  line-height: 1.4;
}

.option-step > p {
  color: #6c6673;
}

.register-form {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 14px;
  margin-top: 14px;
}

.register-form label {
  width: 100%;
  color: #343349;
  font-size: 14.5px;
  font-weight: 650;
}

/* Bloques del paso 1 */

.register-form-section {
  width: 100%;
  background: rgba(255, 250, 242, 0.78);
  border: 1.5px solid #eadfd3;
  border-radius: 17px;
  padding: 15px 16px 16px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 13px 14px;
}

.register-form-section.access-section {
  background: rgba(255, 250, 242, 0.78);
  border-color: #eadfd3;
}

.register-section-title {
  grid-column: 1 / -1;
  margin-bottom: 2px;
}

.register-section-title h3 {
  margin: 0 0 4px;
  color: #343349;
  font-size: 16px;
  font-weight: 850;
}

.register-section-title p {
  margin: 0;
  color: #6c6673;
  font-size: 13.2px;
  line-height: 1.35;
  font-weight: 600;
}

.register-form-section label {
  font-size: 14px;
}

.input-box {
  width: 100%;
  height: 48px;
  margin-top: 6px;
  border: 1.5px solid #eadfd3;
  border-radius: 13px;
  background: #ffffff;
  display: grid;
  grid-template-columns: 52px 1fr;
  align-items: center;
  overflow: hidden;
}

.input-box span {
  color: #6fa04f;
  font-size: 22px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.input-box input {
  width: 100%;
  height: 100%;
  border: none;
  outline: none;
  background: transparent;
  color: #343349;
  font-size: 14.5px;
  font-family: inherit;
}

.input-box input::placeholder {
  color: #9e9a9a;
}

.secure-box {
  width: 100%;
  margin-top: 2px;
  background: rgba(213, 230, 196, 0.3);
  border: 1px solid rgba(111, 160, 79, 0.18);
  border-radius: 15px;
  padding: 11px 13px;
  display: grid;
  grid-template-columns: 40px 1fr;
  align-items: center;
  gap: 10px;
}

.secure-box span {
  width: 38px;
  height: 38px;
  border: 3px solid #6fa04f;
  color: #6fa04f;
  border-radius: 13px;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 20px;
}

.secure-box p {
  margin: 0;
  color: #536246;
  font-size: 13px;
  font-weight: 600;
  line-height: 1.35;
}

/* Botones de opción */

.option-step {
  width: 100%;
}

.option-group {
  margin-bottom: 20px;
}

.option-group h3 {
  margin: 0 0 10px;
  color: #343349;
  font-size: 15px;
  font-weight: 800;
}

.option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 9px;
}

.option-pill {
  height: 36px;
  border: 1.5px solid #eadfd3;
  border-radius: 22px;
  background: #ffffff;
  color: #343349;
  font-family: inherit;
  font-size: 14px;
  font-weight: 600;
  padding: 0 16px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.option-pill:hover {
  border-color: #b8ce78;
}

.option-pill.active {
  background: #b8ce78;
  border-color: #b8ce78;
  color: #ffffff;
  font-weight: 800;
}

.option-help {
  margin: -4px 0 10px;
  color: #7d7785;
  font-size: 13px;
  line-height: 1.3;
}

.care-number-input {
  width: 170px;
  height: 40px;
  border: 1.5px solid #eadfd3;
  border-radius: 13px;
  background: #ffffff;
  color: #343349;
  font-size: 14px;
  font-family: inherit;
  padding: 0 14px;
  outline: none;
}

.care-number-input::placeholder {
  color: #9e9a9a;
}

/* Paso 4: Datos del recién nacido */

.baby-form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px 14px;
}

.baby-form-grid label {
  color: #343349;
  font-size: 14.5px;
  font-weight: 650;
}

.baby-input {
  width: 100%;
  height: 48px;
  margin-top: 7px;
  border: 1.5px solid #eadfd3;
  border-radius: 13px;
  background: #ffffff;
  color: #343349;
  font-size: 14.5px;
  font-family: inherit;
  padding: 0 14px;
  outline: none;
}

.baby-input::placeholder {
  color: #9e9a9a;
}

.baby-input[readonly] {
  background: #f8f4ef;
  color: #6c6673;
  cursor: default;
}

.input-helper {
  display: block;
  margin-top: 5px;
  color: #7d7785;
  font-size: 12.5px;
  font-weight: 500;
}

.baby-sex-group {
  margin-bottom: 0;
}

.baby-classification-card {
  margin-top: 18px;
  background: rgba(213, 230, 196, 0.3);
  border: 1px solid rgba(111, 160, 79, 0.2);
  border-radius: 16px;
  padding: 14px 16px;
}

.baby-classification-card h3 {
  margin: 0 0 10px;
  color: #343349;
  font-size: 15.5px;
  font-weight: 800;
}

.classification-row {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  padding: 7px 0;
  border-bottom: 1px solid rgba(111, 160, 79, 0.14);
  color: #343349;
  font-size: 13.5px;
}

.classification-row:last-child {
  border-bottom: none;
}

.classification-row span {
  color: #6c6673;
  font-weight: 600;
}

.classification-row strong {
  color: #6fa04f;
  text-align: right;
  font-weight: 800;
}

/* Paso 5: Datos clínicos neonatales */

.clinical-step {
  width: 100%;
}

.conditional-group {
  background: rgba(255, 248, 238, 0.75);
  border: 1px solid #f0e2d4;
  border-radius: 15px;
  padding: 13px;
}

.clinical-textarea {
  width: 100%;
  min-height: 78px;
  border: 1.5px solid #eadfd3;
  border-radius: 13px;
  background: #ffffff;
  color: #343349;
  font-size: 14px;
  font-family: inherit;
  padding: 13px;
  outline: none;
  resize: vertical;
}

.clinical-textarea::placeholder {
  color: #9e9a9a;
}

.clinical-info-card {
  margin-top: 16px;
  background: rgba(213, 230, 196, 0.3);
  border: 1px solid rgba(111, 160, 79, 0.2);
  border-radius: 16px;
  padding: 15px 17px;
}

.clinical-info-card h3 {
  margin: 0 0 8px;
  color: #343349;
  font-size: 15.5px;
  font-weight: 800;
}

.clinical-info-card p {
  margin: 0;
  color: #536246;
  font-size: 13.5px;
  line-height: 1.45;
  font-weight: 600;
}

/* Paso 6: Consentimiento informado */

.consent-step {
  width: 100%;
}

.consent-step h2 {
  margin: 0 0 16px;
  color: #343349;
  font-size: 23px;
  font-weight: 800;
}

.consent-card {
  background: rgba(255, 248, 238, 0.85);
  border: 1px solid #f0e2d4;
  border-radius: 16px;
  padding: 18px 20px;
  margin-bottom: 18px;
}

.consent-card p {
  margin: 0 0 13px;
  color: #343349;
  font-size: 14px;
  line-height: 1.5;
}

.consent-card p:last-child {
  margin-bottom: 0;
}

.consent-checkbox {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  background: rgba(213, 230, 196, 0.3);
  border: 1px solid rgba(111, 160, 79, 0.2);
  border-radius: 15px;
  padding: 14px 16px;
  color: #343349;
  font-size: 14.5px;
  font-weight: 700;
  line-height: 1.4;
  cursor: pointer;
}

.consent-checkbox input {
  width: 19px;
  height: 19px;
  margin-top: 2px;
  accent-color: #8ab86c;
  cursor: pointer;
  flex-shrink: 0;
}

.consent-error {
  margin: 12px 0 0;
  color: #c0392b;
  font-size: 13.5px;
  font-weight: 800;
}

.btn-disabled {
  opacity: 0.65;
}

/* Mensaje de error por paso */

.step-error {
  margin: 18px 0 0;
  background: rgba(255, 224, 220, 0.65);
  border: 1px solid rgba(192, 57, 43, 0.25);
  color: #c0392b;
  border-radius: 15px;
  padding: 13px 16px;
  font-size: 14px;
  font-weight: 800;
  line-height: 1.4;
}

/* Botones inferiores */

.register-actions {
  margin-top: 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.register-actions.first-step {
  justify-content: flex-end;
}

.btn-secondary,
.btn-primary {
  height: 46px;
  border-radius: 26px;
  font-family: inherit;
  font-size: 15.5px;
  font-weight: 700;
  cursor: pointer;
  padding: 0 28px;
  white-space: nowrap;
}

.btn-secondary {
  border: 2px solid #8ab86c;
  background: rgba(255, 255, 255, 0.65);
  color: #6fa04f;
}

.btn-primary {
  border: none;
  background: linear-gradient(135deg, #8ab86c, #6fa04f);
  color: #ffffff;
  box-shadow: 0 12px 24px rgba(111, 160, 79, 0.32);
  min-width: 200px;
}

/* Responsive */

@media (max-width: 1100px) {
  .register-screen {
    max-width: 940px;
  }

  .register-main {
    grid-template-columns: 1fr;
  }

  .register-sidebar {
    display: none;
  }

  .register-card {
    grid-template-columns: 1fr;
    gap: 22px;
    padding: 30px;
  }

  .card-illustration {
    height: 260px;
  }

  .register-main-image {
    max-width: 280px;
  }

  .register-form-section {
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 760px) {
  .register-screen {
    width: 100%;
    border-radius: 0;
    padding: 22px 16px 30px;
    margin-top: 0;
  }

  .register-top {
    grid-template-columns: 46px 1fr 46px;
  }

  .register-top.no-back-button {
    grid-template-columns: 1fr 46px;
  }

  .corner-button {
    width: 42px;
    height: 42px;
    font-size: 26px;
  }

  .corner-button.help {
    font-size: 23px;
  }

  .help-tooltip {
    right: -8px;
    width: 285px;
    min-height: auto;
    grid-template-columns: 46px 1fr;
    gap: 10px;
    padding: 14px;
  }

  .help-tooltip-icon {
    width: 42px;
    height: 42px;
    font-size: 19px;
    border-width: 3px;
  }

  .help-tooltip-text strong {
    font-size: 16px;
  }

  .help-tooltip-text p {
    font-size: 13px;
  }

  .help-contact-button {
    grid-column: 1 / -1;
    width: 100%;
    height: 38px;
    font-size: 13px;
  }

  .register-title-area h1 {
    font-size: 25px;
    text-align: left;
  }

  .top-progress {
    width: 100%;
    margin-left: 0;
  }

  .register-main {
    grid-template-columns: 1fr;
  }

  .register-sidebar {
    display: none;
  }

  .register-card {
    grid-template-columns: 1fr;
    padding: 24px 20px;
  }

  .card-illustration {
    height: 210px;
  }

  .register-main-image {
    max-width: 245px;
  }

  .register-form-section {
    grid-template-columns: 1fr;
    padding: 14px;
  }

  .register-actions {
    gap: 16px;
  }

  .register-actions.first-step {
    justify-content: flex-end;
  }

  .btn-secondary,
  .btn-primary {
    flex: 1;
    min-width: auto;
    padding: 0 18px;
    font-size: 15px;
  }

  .register-actions.first-step .btn-primary {
    flex: unset;
    min-width: 190px;
  }

  .care-number-input {
    width: 100%;
  }

  .baby-form-grid {
    grid-template-columns: 1fr;
  }

  .classification-row {
    flex-direction: column;
    gap: 4px;
  }

  .classification-row strong {
    text-align: left;
  }

  .step-error {
    font-size: 13.5px;
    padding: 13px 14px;
  }
}
