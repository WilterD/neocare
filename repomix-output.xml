<file path="frontend/src/pages/History/History.css">
* {
  box-sizing: border-box;
}

.history-page-wrapper {
  width: 100%;
  min-height: 100vh;
  background: #fff6ec;
  font-family: "Segoe UI", Arial, sans-serif;
  color: #343349;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Contenedor principal */

.history-desktop {
  width: calc(100% - 44px);
  max-width: 1180px;
  min-height: 700px;
  margin-top: 10px;
  margin-bottom: 28px;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
  border: 1px solid #eee7df;
  border-radius: 8px;
  display: grid;
  grid-template-columns: 185px minmax(0, 1fr);
  overflow: hidden;
  box-shadow: 0 16px 48px rgba(146, 116, 78, 0.12);
}

/* Menú lateral */

.history-sidebar {
  position: relative;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
  border-right: 1px solid #eadfd3;
  padding: 42px 14px 24px;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.history-sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.history-sidebar-item {
  width: 100%;
  height: 50px;
  border: none;
  border-radius: 16px;
  background: transparent;
  color: #343349;
  font-family: inherit;
  font-size: 15px;
  font-weight: 700;
  display: grid;
  grid-template-columns: 46px 1fr;
  align-items: center;
  text-align: left;
  padding: 0 12px;
  cursor: pointer;
  text-decoration: none;
  transition: color 0.2s ease, background 0.2s ease;
}

.history-sidebar-icon-box {
  width: 42px;
  height: 42px;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: visible;
  background: transparent;
  border-radius: 0;
}

.history-sidebar-icon {
  width: 48px;
  height: 48px;
  object-fit: contain;
  display: block;
  transition: transform 0.2s ease;
}

.history-sidebar-item:hover {
  color: #6fa04f;
  background: transparent;
}

.history-sidebar-item:hover .history-sidebar-icon {
  transform: scale(1.06);
}

.history-sidebar-item.active {
  background: rgba(213, 230, 196, 0.45);
  border: 1.5px solid rgba(111, 160, 79, 0.38);
  color: #6fa04f;
  font-weight: 800;
}

.history-sidebar-item.active .history-sidebar-icon {
  transform: scale(1.08);
}

/* Panel principal */

.history-main-panel {
  min-width: 0;
  padding: 28px 28px 26px;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
  overflow: hidden;
}

/* Encabezado superior */

.history-title-row {
  display: grid;
  grid-template-columns: 300px minmax(0, 1fr);
  align-items: start;
  gap: 22px;
  margin-bottom: 18px;
}

.history-title-left h1 {
  margin: 0;
  color: #343349;
  font-size: 26px;
  font-weight: 850;
  letter-spacing: -0.4px;
  line-height: 1.1;
}

.history-title-left p {
  max-width: 330px;
  margin: 10px 0 0;
  color: #343349;
  font-size: 13px;
  font-weight: 500;
  line-height: 1.55;
}

.history-title-actions {
  width: 100%;
  display: grid;
  grid-template-columns: minmax(245px, 280px) minmax(0, 1fr);
  grid-template-areas:
    "search filters"
    ". baby";
  align-items: center;
  gap: 10px 14px;
  overflow: visible;
}

/* Buscador */

.history-search-box {
  grid-area: search;
  width: 100%;
  max-width: 280px;
  height: 44px;
  border: 1.5px solid #eadfd3;
  border-radius: 12px;
  background: #ffffff;
  display: grid;
  grid-template-columns: 40px minmax(0, 1fr);
  align-items: center;
  overflow: hidden;
  box-shadow: 0 8px 20px rgba(146, 116, 78, 0.06);
}

.history-search-box span {
  color: #343349;
  font-size: 19px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-search-box input {
  width: 100%;
  height: 100%;
  border: none;
  outline: none;
  background: transparent;
  color: #343349;
  font-family: inherit;
  font-size: 12.4px;
  font-weight: 500;
  padding: 0 10px 0 0;
}

.history-search-box input::placeholder {
  color: #85838d;
}

/* Filtros */

.history-risk-filters {
  grid-area: filters;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8px;
  flex-wrap: nowrap;
}

.history-risk-filters > span {
  color: #343349;
  font-size: 12px;
  font-weight: 850;
  white-space: nowrap;
}

.history-risk-filter {
  width: 58px;
  height: 36px;
  border: 1.5px solid #dfe4dc;
  border-radius: 9px;
  background: #ffffff;
  font-family: inherit;
  font-size: 12px;
  font-weight: 850;
  padding: 0;
  cursor: pointer;
  white-space: nowrap;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.history-risk-filter.todos.active {
  background: #3c8b39;
  border-color: #3c8b39;
  color: #ffffff;
}

.history-risk-filter.bajo {
  color: #2f7f2f;
  border-color: rgba(111, 160, 79, 0.35);
}

.history-risk-filter.bajo.active {
  background: #edf7e7;
  border-color: #6fa04f;
}

.history-risk-filter.medio {
  color: #ff7300;
  border-color: rgba(255, 139, 28, 0.38);
}

.history-risk-filter.medio.active {
  background: #fff4da;
  border-color: #ffb74d;
}

.history-risk-filter.alto {
  color: #e53935;
  border-color: rgba(229, 57, 53, 0.35);
}

.history-risk-filter.alto.active {
  background: #ffe8e5;
  border-color: #e53935;
}

/* Selector bebé */

.history-baby-select {
  grid-area: baby;
  justify-self: end;
  display: grid;
  grid-template-columns: auto 150px;
  align-items: center;
  gap: 10px;
}

.history-baby-select span {
  color: #343349;
  font-size: 12px;
  font-weight: 850;
}

.history-baby-select select {
  width: 150px;
  height: 40px;
  border: 1.5px solid #eadfd3;
  border-radius: 10px;
  background: #ffffff;
  color: #11142c;
  font-family: inherit;
  font-size: 12.5px;
  font-weight: 750;
  padding: 0 14px;
  outline: none;
  cursor: pointer;
}

/* Seguimiento actual */

.history-current-card {
  width: 100%;
  min-height: 108px;
  border: 1.5px solid #eadfd3;
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.96);
  padding: 14px 16px;
  box-shadow: 0 10px 26px rgba(146, 116, 78, 0.08);
  margin-bottom: 18px;
  display: grid;
  grid-template-columns: 82px minmax(0, 1fr);
  align-items: center;
  gap: 12px;
  overflow: hidden;
}

.history-current-image-box {
  width: 74px;
  height: 74px;
  display: flex;
  align-items: center;
  justify-content: center;
  justify-self: center;
  align-self: center;
  overflow: visible;
}

.history-current-image {
  width: 74px;
  height: 74px;
  object-fit: contain;
  display: block;
}

.history-current-content {
  width: 100%;
  min-width: 0;
}

.history-current-content h2 {
  margin: 0 0 10px;
  color: #2f7f2f;
  font-size: 15px;
  font-weight: 900;
  line-height: 1.1;
  text-align: left;
}

.history-current-details {
  width: 100%;
  min-width: 0;
  display: grid;
  grid-template-columns: 92px 96px 126px 108px minmax(145px, 1fr) 112px;
  align-items: start;
  gap: 8px;
}

.history-current-item {
  min-width: 0;
  display: grid;
  grid-template-columns: 28px minmax(0, 1fr);
  align-items: start;
  gap: 7px;
}

.history-current-item.result,
.history-current-item.recommendation {
  grid-template-columns: 1fr;
  align-items: start;
}

.history-current-icon {
  width: 28px;
  height: 28px;
  margin-top: 0;
  border-radius: 50%;
  background: #edf7e7;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
  align-self: start;
}

.history-current-icon.image {
  background: #edf7e7 !important;
  border: 1.4px solid rgba(111, 160, 79, 0.28);
  border-radius: 50% !important;
  box-shadow: none !important;
}

.history-current-icon.image img {
  width: 23px;
  height: 23px;
  object-fit: contain;
  display: block;
}

.history-current-item > div,
.history-current-item.result > div,
.history-current-item.recommendation > div {
  min-width: 0;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-start;
  gap: 2px;
}

.history-current-item h3,
.history-current-item.result h3,
.history-current-item.recommendation h3 {
  width: 100%;
  margin: 0;
  color: #11142c;
  font-size: 9.6px;
  font-weight: 900;
  line-height: 1.05;
  text-align: left;
}

.history-current-item p,
.history-current-item.recommendation p {
  margin: 0;
  color: #11142c;
  font-size: 9.6px;
  font-weight: 600;
  line-height: 1.15;
  text-align: left;
}

.history-current-item.recommendation p {
  max-width: 150px;
}

/* Badges de riesgo */

.history-risk-badge {
  min-height: 30px;
  border-radius: 8px;
  padding: 0 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 10.8px;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
}

.history-risk-badge.low {
  background: #edf7e7;
  color: #2f7f2f;
  border: 1.4px solid rgba(111, 160, 79, 0.35);
}

.history-risk-badge.medium {
  background: #fff4da;
  color: #ff7300;
  border: 1.4px solid rgba(255, 139, 28, 0.35);
}

.history-risk-badge.high {
  background: #ffe8e5;
  color: #e53935;
  border: 1.4px solid rgba(229, 57, 53, 0.35);
}

.history-current-item .history-risk-badge {
  width: 92px;
  height: 26px;
  min-height: 26px;
  padding: 0 8px;
  border-radius: 8px;
  font-size: 9.4px;
  font-weight: 900;
  justify-self: start;
  align-self: start;
  margin-top: 1px;
}

/* Botón ver último resultado */

.history-result-button {
  width: 112px;
  height: 46px;
  border: none;
  border-radius: 9px;
  background: linear-gradient(135deg, #4f963f, #2f7f2f);
  color: #ffffff;
  font-family: inherit;
  font-size: 10.4px;
  font-weight: 850;
  padding: 0 10px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  cursor: pointer;
  justify-self: end;
  align-self: center;
  box-shadow: 0 10px 20px rgba(47, 127, 47, 0.2);
  transition: all 0.2s ease;
}

.history-result-button span {
  font-size: 17px;
  line-height: 1;
}

.history-result-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 14px 26px rgba(47, 127, 47, 0.27);
}

/* Tarjetas resumen */

.history-summary-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18px;
  margin-bottom: 20px;
  align-items: stretch;
}

.history-summary-card {
  min-height: 118px;
  border: 1.5px solid #eadfd3;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.98);
  display: grid;
  grid-template-columns: 62px minmax(0, 1fr);
  align-items: stretch;
  gap: 12px;
  padding: 16px 16px;
  box-shadow: 0 8px 22px rgba(146, 116, 78, 0.06);
}

.history-summary-card.purple {
  border-color: rgba(139, 105, 255, 0.22);
}

.history-summary-card.orange {
  border-color: rgba(255, 139, 28, 0.22);
}

.history-summary-card.green {
  border-color: rgba(111, 160, 79, 0.24);
}

.history-summary-card.blue {
  border-color: rgba(64, 156, 255, 0.24);
}

.history-summary-icon {
  width: 56px;
  height: 56px;
  border-radius: 0;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  align-self: center;
  overflow: visible;
}

.history-summary-icon.image {
  background: transparent !important;
  border-radius: 0 !important;
  box-shadow: none !important;
}

.history-summary-icon.image img {
  width: 58px !important;
  height: 58px !important;
  object-fit: contain;
  display: block;
}

/* RECIENTE - Cambio reciente duplicado */

.history-summary-card.orange .history-summary-icon {
  width: 72px;
  height: 72px;
  overflow: visible;
}

.history-summary-card.orange .history-summary-icon.image img {
  width: 78px !important;
  height: 116px !important;
  object-fit: contain;
  display: block;
}

/* TVR - Seguimientos activos triplicado */

.history-summary-card.green .history-summary-icon {
  width: 82px;
  height: 82px;
  overflow: visible;
}

.history-summary-card.green .history-summary-icon.image img {
  width: 120px !important;
  height: 174px !important;
  object-fit: contain;
  display: block;
}

/* Contenido interno de tarjetas resumen */

.history-summary-card > div {
  min-width: 0;
  height: 100%;
  min-height: 86px;
  display: grid;
  grid-template-rows: 38px 1fr 28px;
  align-items: start;
  justify-items: start;
  gap: 2px;
}

.history-summary-card h3 {
  width: 100%;
  margin: 0;
  color: #11142c;
  font-size: 12px !important;
  font-weight: 900;
  line-height: 1.2;
  text-align: left;
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  align-self: start;
}

.history-summary-card p {
  width: 100%;
  margin: 0;
  color: #11142c;
  font-size: 11.5px !important;
  font-weight: 600;
  line-height: 1.25;
  text-align: left;
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  gap: 4px;
  align-self: start;
}

.history-summary-card p strong {
  color: #11142c;
  font-size: 20px !important;
  font-weight: 950;
  line-height: 1.05;
  display: inline-block;
  margin-right: 4px;
}

.history-summary-card.orange > div {
  grid-template-rows: 32px 28px 30px;
  justify-content: start;
}

.history-summary-card.orange p {
  align-self: start;
}

.history-summary-card.orange .history-risk-badge {
  width: auto;
  height: 28px;
  min-height: 28px;
  margin-top: 0;
  padding: 0 14px;
  border-radius: 9px;
  font-size: 10.8px;
  align-self: end;
  justify-self: start;
}

.history-summary-card.blue > div {
  grid-template-rows: 46px 1fr;
  gap: 4px;
}

.history-summary-card.blue h3 {
  align-self: start;
}

.history-summary-card.blue p {
  align-self: start;
}

.history-summary-card.blue p strong {
  display: block;
  margin-right: 0;
  color: #11142c;
  font-size: 17px !important;
  font-weight: 950;
  line-height: 1.05;
  margin-top: 2px;
}

/* Sección evaluaciones anteriores */

.history-evaluations-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  margin: 4px 0 12px;
}

.history-section-title {
  display: flex;
  align-items: center;
  gap: 12px;
}

.history-section-title-image {
  width: 34px;
  height: 34px;
  object-fit: contain;
  display: block;
}

.history-section-title h2 {
  margin: 0;
  color: #11142c;
  font-size: 20px;
  font-weight: 900;
  line-height: 1.15;
}

.history-order-box {
  display: flex;
  align-items: center;
  gap: 10px;
}

.history-order-box span {
  color: #343349;
  font-size: 12px;
  font-weight: 700;
}

.history-order-box select {
  height: 38px;
  border: 1.5px solid #eadfd3;
  border-radius: 9px;
  background: #ffffff;
  color: #343349;
  font-family: inherit;
  font-size: 12.5px;
  font-weight: 750;
  padding: 0 14px;
  outline: none;
  cursor: pointer;
}

/* Tabla */

.history-table-card {
  width: 100%;
  border: 1.5px solid #eadfd3;
  border-radius: 12px;
  background: #ffffff;
  overflow: hidden;
  box-shadow: 0 10px 24px rgba(146, 116, 78, 0.07);
}

.history-table {
  width: 100%;
  border-collapse: collapse;
  table-layout: fixed;
}

.history-table thead {
  background: #fffaf2;
}

.history-table th {
  color: #343349;
  font-size: 11.2px;
  font-weight: 900;
  text-align: left;
  padding: 13px 14px;
  border-bottom: 1px solid #eadfd3;
  white-space: nowrap;
}

.history-table td {
  color: #343349;
  font-size: 12px;
  font-weight: 600;
  line-height: 1.35;
  padding: 12px 14px;
  border-bottom: 1px solid #eadfd3;
  vertical-align: middle;
}

.history-table tbody tr:last-child td {
  border-bottom: none;
}

/* Distribución corregida de columnas */

.history-table th:nth-child(1),
.history-table td:nth-child(1) {
  width: 21%;
}

.history-table th:nth-child(2),
.history-table td:nth-child(2) {
  width: 10%;
}

.history-table th:nth-child(3),
.history-table td:nth-child(3) {
  width: 17%;
}

.history-table th:nth-child(4),
.history-table td:nth-child(4) {
  width: 18%;
}

.history-table th:nth-child(5),
.history-table td:nth-child(5) {
  width: 20%;
}

.history-table th:nth-child(6),
.history-table td:nth-child(6) {
  width: 14%;
  text-align: center;
  padding-left: 8px;
  padding-right: 8px;
}

/* Fecha */

.history-date-cell {
  display: grid;
  grid-template-columns: 36px minmax(0, 1fr);
  align-items: center;
  gap: 10px;
}

.history-date-cell strong {
  display: block;
  color: #11142c;
  font-size: 12.5px;
  font-weight: 900;
  line-height: 1.2;
}

.history-date-cell p {
  margin: 3px 0 0;
  color: #686a75;
  font-size: 11.5px;
  font-weight: 600;
}

/* Iconos tabla */

.history-table-icon {
  width: 32px;
  height: 32px;
  border-radius: 0;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.history-table-icon.image {
  background: transparent !important;
  border-radius: 0 !important;
  box-shadow: none !important;
}

.history-table-icon.image img {
  width: 38px;
  height: 38px;
  object-fit: contain;
  display: block;
}

/* Tipo de seguimiento */

.history-tracking-cell {
  display: grid;
  grid-template-columns: 28px minmax(0, 1fr);
  align-items: center;
  gap: 8px;
}

.history-tracking-cell span:last-child {
  color: #343349;
  font-size: 11.6px;
  font-weight: 700;
  line-height: 1.25;
  word-break: normal;
}

/* Recomendación */

.history-table td:nth-child(5) {
  font-size: 11.6px;
  line-height: 1.35;
}

/* Botones tabla */

.history-detail-button {
  width: 104px;
  max-width: 100%;
  height: 36px;
  border: 1.5px solid #6fa04f;
  border-radius: 9px;
  background: #ffffff;
  color: #2f7f2f;
  font-family: inherit;
  font-size: 11.4px;
  font-weight: 850;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
  padding: 0 8px;
  white-space: nowrap;
  overflow: hidden;
  cursor: pointer;
  transition: all 0.2s ease;
}

.history-detail-button span {
  font-size: 18px;
  line-height: 1;
  flex-shrink: 0;
}

.history-detail-button:hover {
  background: #edf7e7;
  transform: translateY(-1px);
}

.history-table-footer {
  min-height: 48px;
  border-top: 1px solid #eadfd3;
  background: #fffdf8;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  padding: 0 18px;
}

.history-table-footer p {
  margin: 0;
  color: #343349;
  font-size: 12px;
  font-weight: 700;
}

/* Botón Ver todas las evaluaciones */

.history-view-all-button {
  border: none;
  background: transparent;
  color: #2f7f2f;
  font-family: inherit;
  font-size: 12px;
  font-weight: 850;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  padding: 8px 10px;
  border-radius: 9px;
  transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
}

.history-view-all-button span {
  font-size: 22px;
  line-height: 1;
  transition: transform 0.2s ease;
}

.history-view-all-button:hover {
  background: rgba(111, 160, 79, 0.12);
  color: #1f6b25;
  transform: translateY(-1px);
}

.history-view-all-button:hover span {
  transform: translateX(3px);
}

/* Estado vacío */

.history-empty-state {
  width: 100%;
  min-height: 92px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  text-align: center;
}

.history-empty-state h3 {
  margin: 0;
  color: #11142c;
  font-size: 14px;
  font-weight: 900;
}

.history-empty-state p {
  margin: 0;
  color: #686a75;
  font-size: 12px;
  font-weight: 600;
  line-height: 1.35;
}

/* Footer */

.history-page-wrapper .app-footer {
  width: 100%;
  margin-top: 0;
}

/* Responsive */

@media (max-width: 1100px) {
  .history-desktop {
    grid-template-columns: 1fr;
  }

  .history-sidebar {
    /* Removed display none, handled by index.css */
  }

  .history-title-row {
    grid-template-columns: 1fr;
  }

  .history-title-actions {
    grid-template-columns: 1fr;
    grid-template-areas:
      "search"
      "filters"
      "baby";
    justify-items: start;
  }

  .history-search-box {
    max-width: 100%;
  }

  .history-risk-filters {
    justify-content: flex-start;
    flex-wrap: wrap;
  }

  .history-baby-select {
    justify-self: start;
  }

  .history-current-card {
    grid-template-columns: 1fr;
  }

  .history-current-image-box {
    justify-self: center;
  }

  .history-current-details {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .history-result-button {
    justify-self: start;
  }

  .history-summary-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .history-table-card {
    overflow-x: auto;
  }

  .history-table {
    min-width: 850px;
  }
}

@media (max-width: 760px) {
  .history-desktop {
    width: 100%;
    margin-top: 0;
    margin-bottom: 0;
    border-radius: 0;
    border-left: none;
    border-right: none;
  }

  .history-main-panel {
    padding: 24px 18px;
  }

  .history-title-left h1 {
    font-size: 23px;
  }

  .history-title-actions {
    grid-template-columns: 1fr;
  }

  .history-baby-select {
    grid-template-columns: 70px 1fr;
  }

  .history-current-details,
  .history-summary-grid {
    grid-template-columns: 1fr;
  }

  .history-result-button {
    justify-self: stretch;
    width: 100%;
  }

  .history-evaluations-section {
    flex-direction: column;
    align-items: flex-start;
  }

  .history-order-box {
    width: 100%;
    justify-content: space-between;
  }

  .history-order-box select {
    min-width: 170px;
  }
}

@media (max-width: 430px) {
  .history-main-panel {
    padding: 22px 14px;
  }

  .history-title-left h1 {
    font-size: 21px;
  }

  .history-current-card,
  .history-summary-card,
  .history-table-card {
    border-radius: 14px;
  }

  .history-current-image {
    width: 70px;
    height: 70px;
  }

  .history-summary-icon.image img {
    width: 58px !important;
    height: 58px !important;
  }

  .history-table-footer {
    flex-direction: column;
    align-items: flex-start;
    padding: 14px 18px;
  }
}
