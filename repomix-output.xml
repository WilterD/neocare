.bebes-stat-card div span {
  display: block;
  color: #6b6b7c;
  font-size: 12px;
  font-weight: 600;
}

.bebes-stat-card div strong {
  display: block;
  color: #343349;
  font-size: 22px;
  font-weight: 850;
  margin-top: 2px;
}

.bebes-stat-card.bajo strong { color: #6fa04f; }
.bebes-stat-card.moderado strong { color: #c98a2a; }
.bebes-stat-card.alto strong { color: #c64a4a; }

/* ===== Filtros ===== */
.bebes-filter-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 22px;
  padding: 12px 16px;
  background: rgba(255, 255, 255, 0.55);
  border: 1px solid #ece2d4;
  border-radius: 14px;
}

.bebes-filter-label {
  color: #6b6b7c;
  font-size: 13px;
  font-weight: 700;
  margin-right: 6px;
}

.bebes-filter-button {
  border: 1.5px solid #e2d8cf;
  background: #ffffff;
  color: #343349;
  font-family: inherit;
  font-size: 13px;
  font-weight: 700;
  padding: 8px 14px;
  border-radius: 999px;
  cursor: pointer;
  transition: all 0.18s ease;
}

.bebes-filter-button:hover {
  border-color: #6fa04f;
  color: #6fa04f;
}

.bebes-filter-button.active {
  background: #6fa04f;
  border-color: #6fa04f;
  color: #ffffff;
}

.bebes-filter-button.active.bajo {
  background: #6fa04f;
  border-color: #6fa04f;
}
.bebes-filter-button.active.moderado {
  background: #e0a64a;
  border-color: #e0a64a;
}
.bebes-filter-button.active.alto {
  background: #c64a4a;
  border-color: #c64a4a;
}
.bebes-filter-button.active.sin {
  background: #77717b;
  border-color: #77717b;
}

/* ===== Estado vacío / error ===== */
.bebes-state-card {
  text-align: center;
  padding: 36px 20px;
  background: #ffffff;
  border: 1.5px dashed #e2d8cf;
  border-radius: 16px;
  margin-bottom: 18px;
  color: #6b6b7c;
}

.bebes-state-card img {
  width: 80px;
  height: 80px;
  object-fit: contain;
  margin-bottom: 8px;
  opacity: 0.6;
}

.bebes-state-card.error {
  border-color: #c64a4a;
  color: #c64a4a;
}

.bebes-retry-button {
  margin-top: 12px;
  border: none;
  background: #6fa04f;
  color: #fff;
  font-family: inherit;
  font-size: 14px;
  font-weight: 700;
  padding: 8px 18px;
  border-radius: 999px;
  cursor: pointer;
}

/* ===== Grid de bebés ===== */
.bebes-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
  margin-bottom: 22px;
}

.bebe-card {
  display: flex;
  flex-direction: column;
  background: #ffffff;
  border: 1.5px solid #ece2d4;
  border-radius: 18px;
  padding: 16px 18px;
