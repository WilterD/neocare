.contact-emergency-inside h3 {
  margin: 0 0 8px;
  color: #c71e1e;
  font-size: 18px;
  font-weight: 850;
}

.contact-emergency-inside p {
  margin: 0 0 10px;
  color: #3c2b29;
  font-size: 13.5px;
  font-weight: 500;
