<file path="frontend/src/pages/Home/Home.css">
* {
  box-sizing: border-box;
}

.home-page-wrapper {
  width: 100%;
  min-height: 100vh;
  background: #fff6ec;
  font-family: "Segoe UI", Arial, sans-serif;
  color: #343349;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Contenedor principal igual a Education, Evaluation, History y Result */

.home-desktop {
  width: calc(100% - 44px);
  max-width: 1180px;
  min-height: 700px;
  margin-top: 10px;
  margin-bottom: 28px;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
  border: 1px solid #eee7df;
  border-radius: 8px;
  display: grid;
  grid-template-columns: 185px 1fr;
  overflow: visible;
  box-shadow: 0 16px 48px rgba(146, 116, 78, 0.12);
}

/* Sidebar igual a las demás pantallas */

.home-sidebar {
  position: relative;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
  border-right: 1px solid #eadfd3;
  padding: 42px 14px 24px;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.home-sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.home-sidebar-item {
  width: 100%;
  height: 50px;
  border: none;
  border-radius: 16px;
  background: transparent;
  color: #343349;
  font-family: inherit;
  font-size: 15px;
  font-weight: 700;
  display: grid;
  grid-template-columns: 46px 1fr;
  align-items: center;
  text-align: left;
  padding: 0 12px;
  cursor: pointer;
  text-decoration: none;
  transition: color 0.2s ease, background 0.2s ease;
}

.home-sidebar-icon-box {
  width: 42px;
  height: 42px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.home-sidebar-icon {
  width: 48px;
  height: 48px;
  object-fit: contain;
  display: block;
  transition: transform 0.2s ease;
}

.home-sidebar-item:hover {
  color: #6fa04f;
  background: transparent;
}

.home-sidebar-item:hover .home-sidebar-icon {
  transform: scale(1.06);
}

.home-sidebar-item.active {
  background: rgba(213, 230, 196, 0.45);
  border: 1.5px solid rgba(111, 160, 79, 0.38);
  color: #6fa04f;
  font-weight: 800;
}

.home-sidebar-item.active .home-sidebar-icon {
  transform: scale(1.08);
}

/* Panel principal */

.home-main-panel {
  padding: 32px 28px 28px;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
}

/* Hero superior */

.home-hero-section {
  min-height: 166px;
  display: grid;
  grid-template-columns: 1fr 310px;
  align-items: center;
  gap: 24px;
  margin-bottom: 16px;
}

.home-hero-text h1 {
  margin: 0 0 10px;
  color: #343349;
  font-size: 26px;
  font-weight: 850;
  letter-spacing: -0.4px;
  line-height: 1.1;
}

.home-hero-text h2 {
  margin: 0 0 14px;
  color: #0d5f1f;
  font-size: 15px;
  font-weight: 850;
  line-height: 1.3;
}

.home-hero-text p {
  margin: 0;
  max-width: 580px;
  color: #343349;
  font-size: 14px;
  font-weight: 500;
  line-height: 1.55;
}

.home-hero-image-box {
  height: 156px;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: visible;
}

.home-hero-image {
  width: 190px;
  height: 190px;
  object-fit: contain;
  display: block;
}

/* Seguimiento actual */

.home-current-card {
  min-height: 138px;
  border: 1.5px solid #f2d9b8;
  border-radius: 16px;
  background:
    radial-gradient(circle at 7% 50%, rgba(255, 139, 28, 0.14) 0%, transparent 25%),
    linear-gradient(135deg, #fffaf2 0%, #fffdf8 100%);
  display: grid;
  grid-template-columns: 125px 1fr;
  align-items: center;
  gap: 18px;
  padding: 16px 20px;
  margin-bottom: 16px;
  box-shadow: 0 14px 32px rgba(146, 116, 78, 0.08);
}

.home-current-main-icon {
  width: 104px;
  height: 104px;
  border-radius: 50%;
  background: #fff0d7;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.home-current-main-icon img {
  width: 118px;
  height: 118px;
  object-fit: contain;
  display: block;
}

.home-current-content {
  min-width: 0;
}

.home-current-content h2 {
  margin: 0 0 12px;
  color: #ff7300;
  font-size: 21px;
  font-weight: 900;
  line-height: 1.1;
}

.home-current-data {
  min-width: 0;
  display: grid;
  grid-template-columns: 110px 120px 145px 150px minmax(120px, 1fr);
  grid-template-areas:
    "baby age last result empty"
    "recommendation recommendation recommendation recommendation recommendation";
  align-items: start;
  gap: 12px 16px;
}

.home-current-item {
  min-width: 0;
  min-height: 40px;
  display: grid;
  grid-template-columns: 28px minmax(0, 1fr);
  align-items: start;
  gap: 7px;
}

.home-current-item:nth-child(1) {
  grid-area: baby;
}

.home-current-item:nth-child(2) {
  grid-area: age;
}

.home-current-item:nth-child(3) {
  grid-area: last;
}

.home-current-item:nth-child(4) {
  grid-area: result;
}

.home-current-item:nth-child(5) {
  grid-area: recommendation;
}

.home-current-item.result,
.home-current-item.recommendation {
  grid-template-columns: 1fr;
}

.home-current-item.result {
  align-self: start;
}

.home-current-item.recommendation {
  margin-top: 2px;
}

.home-current-small-icon {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: #fff0d7;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.home-current-small-icon img {
  width: 30px;
  height: 30px;
  object-fit: contain;
  display: block;
}

.home-current-small-icon.baby {
  width: 30px;
  height: 29px;
  overflow: visible;
}

.home-current-small-icon.baby img {
  width: 62px !important;
  height: 62px !important;
  object-fit: contain;
  display: block;
}

.home-current-item h3 {
  margin: 0 0 4px;
  color: #343349;
  font-size: 10.7px;
  font-weight: 850;
  line-height: 1.1;
  white-space: nowrap;
}

.home-current-item p {
  margin: 0;
  color: #343349;
  font-size: 11.3px;
  font-weight: 600;
  line-height: 1.3;
}

/* Riesgo */

.home-risk-badge {
  min-width: 110px;
  height: 32px;
  border-radius: 10px;
  display: inline-flex;
  justify-content: center;
  align-items: center;
  gap: 7px;
  font-size: 12.2px;
  font-weight: 850;
  padding: 0 12px;
  white-space: nowrap;
}

.home-risk-badge::before {
  content: "";
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: block;
}

.home-risk-badge.medium {
  background: #fff3df;
  border: 1.4px solid #ffd49b;
  color: #f08315;
}

.home-risk-badge.medium::before {
  background: #ff9b22;
}

/* Métricas */

.home-metrics-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16px;
  margin-bottom: 16px;
}

.home-metric-card {
  min-height: 90px;
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.96);
  border: 1.5px solid #eadfd3;
  display: grid;
  grid-template-columns: 68px 1fr;
  align-items: center;
  gap: 12px;
  padding: 12px 18px;
  box-shadow: 0 12px 28px rgba(146, 116, 78, 0.08);
}

.home-metric-card.blue {
  border-color: rgba(45, 155, 234, 0.25);
}

.home-metric-card.purple {
  border-color: rgba(148, 104, 220, 0.25);
}

.home-metric-card.red {
  border-color: rgba(255, 82, 82, 0.25);
}

.home-metric-icon.image {
  width: 58px;
  height: 58px;
  border-radius: 0;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
  align-self: center;
}

.home-metric-icon.image img {
  width: 68px;
  height: 68px;
  object-fit: contain;
  display: block;
}

/* INICIOPROXI sin círculo azul */
.home-metric-icon.image.proxi {
  width: 58px;
  height: 58px;
  border-radius: 0;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.home-metric-icon.image.proxi img {
  width: 68px;
  height: 68px;
  object-fit: contain;
  display: block;
}

.home-metric-text {
  min-width: 0;
  height: 54px;
  display: grid;
  grid-template-rows: 32px 18px;
  align-items: start;
  gap: 3px;
}

.home-metric-card h3 {
  margin: 0;
  color: #11142c;
  font-size: 15px;
  font-weight: 850;
  line-height: 1.12;
  min-height: 32px;
  display: flex;
  align-items: flex-start;
}

.home-metric-value {
  margin: 0;
  color: #11142c;
  font-size: 12.8px;
  font-weight: 500;
  line-height: 1.2;
}

.home-metric-value strong {
  color: #11142c;
  font-size: 16px;
  font-weight: 900;
  line-height: 1;
}

/* Secciones medias */

.home-middle-grid {
  display: grid;
  grid-template-columns: 0.9fr 1.1fr;
  gap: 16px;
  margin-bottom: 16px;
}

.home-next-card,
.home-access-card,
.home-reminder-card {
  border: 1.5px solid #eadfd3;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 14px 32px rgba(146, 116, 78, 0.08);
}

/* Próxima acción recomendada */

.home-next-card {
  padding: 20px 24px;
  border: 1.5px solid #f2d9b8;
  background:
    radial-gradient(circle at 8% 50%, rgba(255, 139, 28, 0.14) 0%, transparent 24%),
    linear-gradient(135deg, #fffaf2 0%, #fffdf8 100%);
}

.home-next-card h2,
.home-access-card h2,
.home-reminder-card h2 {
  margin: 0 0 18px;
  color: #11142c;
  font-size: 19px;
  font-weight: 850;
}

.home-next-content {
  display: grid;
  grid-template-columns: 90px 1fr;
  gap: 18px;
  align-items: center;
}

.home-next-icon {
  width: 82px;
  height: 82px;
  border-radius: 50%;
  background: #fff0d7;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.home-next-icon img {
  width: 96px;
  height: 96px;
  object-fit: contain;
  display: block;
}

.home-next-text h3 {
  margin: 0 0 8px;
  color: #ff7300;
  font-size: 18px;
  font-weight: 900;
}

.home-next-text p {
  margin: 0 0 18px;
  color: #343349;
  font-size: 13px;
  font-weight: 500;
  line-height: 1.45;
}

.home-orange-button {
  min-width: 190px;
  height: 42px;
  border: none;
  border-radius: 10px;
  background: linear-gradient(135deg, #ff850b, #ff6a00);
  color: #ffffff;
  font-family: inherit;
  font-size: 13.3px;
  font-weight: 850;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  cursor: pointer;
  box-shadow: 0 12px 24px rgba(255, 106, 0, 0.22);
  transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease;
}

.home-orange-button:hover {
  transform: translateY(-3px);
  box-shadow: 0 18px 32px rgba(255, 106, 0, 0.3);
  filter: brightness(1.03);
}

.home-orange-button span {
  font-size: 23px;
}

/* Accesos útiles */

.home-access-card {
  padding: 20px 22px;
}

.home-access-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
}

.home-access-item {
  min-height: 165px;
  border: 1.5px solid #eadfd3;
  border-radius: 13px;
  background: #ffffff;
  text-align: left;
  font-family: inherit;
  color: #343349;
  padding: 12px 12px 12px;
  cursor: pointer;

  display: grid;
  grid-template-columns: 48px minmax(0, 1fr);
  grid-template-rows: 48px 1fr 24px;
  grid-template-areas:
    "icon title"
    "text text"
    "arrow arrow";
  align-items: start;
  gap: 8px 8px;

  transition: transform 0.22s ease, box-shadow 0.22s ease,
    border-color 0.22s ease;
}

.home-access-item:hover {
  transform: translateY(-3px);
  box-shadow: 0 16px 30px rgba(146, 116, 78, 0.16);
  border-color: rgba(111, 160, 79, 0.32);
}

.home-access-item.green {
  background: #fbfff6;
}

.home-access-item.purple {
  background: #fbf8ff;
}

.home-access-item.blue {
  background: #f7fbff;
}

.home-access-icon.image {
  grid-area: icon;
  width: 44px;
  height: 44px;
  border-radius: 0;
  background: transparent;
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  overflow: visible;
  align-self: start;
  justify-self: start;
  margin-left: -2px;
  margin-top: -2px;
}

.home-access-icon.image img {
  width: 52px;
  height: 52px;
  object-fit: contain;
  display: block;
}

/* TVR y Libreta más grandes, pero sin invadir el título */
.home-access-item.green .home-access-icon.image img,
.home-access-item.purple .home-access-icon.image img {
  width: 66px;
  height: 66px;
  margin-left: -7px;
  margin-top: -7px;
}

/* Ver historial sin círculo azul debajo */
.home-access-icon.image.history {
  width: 44px;
  height: 44px;
  border-radius: 0;
  background: transparent;
}

.home-access-icon.image.history img {
  width: 52px;
  height: 52px;
  object-fit: contain;
  display: block;
}

.home-access-item h3 {
  grid-area: title;
  margin: 0;
  color: #11142c;
  font-size: 11.4px;
  font-weight: 850;
  line-height: 1.15;
  align-self: center;
  max-width: 100%;
  overflow-wrap: break-word;
  word-break: normal;
}

.home-access-item p {
  grid-area: text;
  margin: 2px 0 0;
  color: #343349;
  font-size: 11.3px;
  font-weight: 500;
  line-height: 1.35;
  align-self: start;
}

.home-access-arrow {
  grid-area: arrow;
  color: inherit;
  font-size: 25px;
  font-weight: 500;
  line-height: 1;
  justify-self: start;
  align-self: end;
}

/* Bloque inferior */

.home-bottom-grid {
  display: grid;
  grid-template-columns: 1fr 0.95fr;
  gap: 16px;
}

.home-reminder-card {
  min-height: 112px;
  padding: 16px 20px;
  display: grid;
  grid-template-columns: 100px 1fr;
  align-items: center;
  gap: 16px;
  background:
    radial-gradient(circle at 8% 50%, rgba(111, 160, 79, 0.13) 0%, transparent 24%),
    linear-gradient(135deg, #f6fbf1 0%, #fffdf8 100%);
  border-color: #dbe7cf;
}

.home-reminder-image {
  width: 86px;
  height: 76px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-reminder-image img {
  width: 104px;
  height: 104px;
  object-fit: contain;
}

.home-reminder-card h2 {
  margin: 0 0 8px;
  color: #11142c;
  font-size: 18px;
  font-weight: 850;
}

.home-reminder-card p {
  margin: 0;
  color: #343349;
  font-size: 12.8px;
  font-weight: 500;
  line-height: 1.45;
}

/* Footer */

.home-page-wrapper .app-footer {
  width: 100%;
  margin-top: 0;
}

/* Responsive */

@media (max-width: 1120px) {
  .home-hero-section,
  .home-current-card,
  .home-middle-grid,
  .home-bottom-grid {
    grid-template-columns: 1fr;
  }

  .home-current-data {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-template-areas:
      "baby age"
      "last result"
      "recommendation recommendation";
  }

  .home-metrics-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 1050px) {
  .home-desktop {
    grid-template-columns: 1fr;
  }

  .home-sidebar {
    /* Removed display none, handled by index.css */
  }
}

@media (max-width: 760px) {
  .home-desktop {
    width: 100%;
    margin-top: 0;
    border-radius: 0;
    border-left: none;
    border-right: none;
  }

  .home-main-panel {
    padding: 26px 18px;
  }

  .home-hero-image-box {
    display: none;
  }

  .home-current-data,
  .home-access-grid,
  .home-reminder-card {
    grid-template-columns: 1fr;
  }

  .home-current-data {
    grid-template-areas:
      "baby"
      "age"
      "last"
      "result"
      "recommendation";
  }
}

@media (max-width: 430px) {
  .home-main-panel {
    padding: 22px 14px;
  }

  .home-hero-text h1 {
    font-size: 23px;
  }

  .home-current-card,
  .home-next-card,
  .home-access-card,
  .home-reminder-card {
    border-radius: 14px;
  }

  .home-next-content {
    grid-template-columns: 1fr;
  }

  .home-orange-button {
    width: 100%;
  }
  
}
