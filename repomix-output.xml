<file path="frontend/src/pages/Evaluation/Evaluation.css">
* {
  box-sizing: border-box;
}

.evaluation-page-wrapper {
  width: 100%;
  min-height: 100vh;
  background: #fff6ec;
  font-family: "Segoe UI", Arial, sans-serif;
  color: #343349;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Contenedor principal */

.evaluation-desktop {
  width: calc(100% - 44px);
  max-width: 1180px;
  min-height: 700px;
  margin-top: 10px;
  margin-bottom: 28px;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
  border: 1px solid #eee7df;
  border-radius: 8px;
  display: grid;
  grid-template-columns: 185px 1fr;
  overflow: hidden;
  box-shadow: 0 16px 48px rgba(146, 116, 78, 0.12);
}

/* Sidebar */

.evaluation-sidebar {
  position: relative;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
  border-right: 1px solid #eadfd3;
  padding: 42px 14px 24px;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.evaluation-sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.evaluation-sidebar-item {
  width: 100%;
  height: 50px;
  border: none;
  border-radius: 16px;
  background: transparent;
  color: #343349;
  font-family: inherit;
  font-size: 15px;
  font-weight: 700;
  display: grid;
  grid-template-columns: 46px 1fr;
  align-items: center;
  text-align: left;
  padding: 0 12px;
  cursor: pointer;
  text-decoration: none;
  transition: color 0.2s ease, background 0.2s ease;
}

/* Imágenes del menú lateral */

.evaluation-sidebar-icon-box {
  width: 42px;
  height: 42px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.evaluation-sidebar-icon {
  width: 48px;
  height: 48px;
  object-fit: contain;
  display: block;
  transition: transform 0.2s ease;
}

/* Hover: solo texto e imagen, sin bloque */

.evaluation-sidebar-item:hover {
  color: #6fa04f;
  background: transparent;
}

.evaluation-sidebar-item:hover .evaluation-sidebar-icon {
  transform: scale(1.06);
}

/* Activo: bloque verde solo en la pantalla activa */

.evaluation-sidebar-item.active {
  background: rgba(213, 230, 196, 0.45);
  border: 1.5px solid rgba(111, 160, 79, 0.38);
  color: #6fa04f;
  font-weight: 800;
}

.evaluation-sidebar-item.active .evaluation-sidebar-icon {
  transform: scale(1.08);
}

/* Panel principal */

.evaluation-main-panel {
  padding: 32px 28px 28px;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
}

/* Título */

.evaluation-title-row {
  display: grid;
  grid-template-columns: 1fr 42px;
  align-items: center;
  gap: 14px;
  margin-bottom: 24px;
}

.evaluation-title-row h1 {
  margin: 0;
  color: #343349;
  font-size: 26px;
  font-weight: 850;
  letter-spacing: -0.4px;
}

.evaluation-help-button {
  width: 38px;
  height: 38px;
  justify-self: end;
  border: 3px solid #6fa04f;
  border-radius: 50%;
  background: transparent;
  color: #6fa04f;
  font-family: inherit;
  font-size: 22px;
  font-weight: 850;
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
}

/* Hero */

.evaluation-hero-card {
  min-height: 136px;
  border: 1.5px solid #eadfd3;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.96);
  display: grid;
  grid-template-columns: 180px 1fr;
  align-items: center;
  gap: 16px;
  padding: 16px 24px;
  overflow: hidden;
  position: relative;
  box-shadow: 0 14px 32px rgba(146, 116, 78, 0.08);
}

/* Imagen CT del hero */

.evaluation-hero-image-box {
  width: 180px;
  height: 116px;
  display: flex;
  justify-content: center;
  align-items: center;
  justify-self: center;
  overflow: visible;
}

.evaluation-hero-image {
  width: 250px;
  height: 250px;
  object-fit: contain;
  display: block;
}

.evaluation-hero-text h2 {
  margin: 0 0 10px;
  color: #343349;
  font-size: 22px;
  font-weight: 850;
}

.evaluation-hero-text p {
  margin: 0;
  color: #343349;
  font-size: 15.5px;
  line-height: 1.5;
  max-width: 520px;
}

/* Grid central */

.evaluation-grid-content {
  margin-top: 20px;
  display: grid;
  grid-template-columns: 1.45fr 0.95fr;
  gap: 22px;
  align-items: start;
}

/* Resumen */

.evaluation-summary-card {
  background: rgba(255, 255, 255, 0.96);
  border: 1.5px solid #eadfd3;
  border-radius: 22px;
  padding: 22px 24px 12px;
  box-shadow: 0 18px 45px rgba(146, 116, 78, 0.14);
}

.evaluation-summary-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14px;
}

.evaluation-summary-header h2 {
  margin: 0;
  color: #343349;
  font-size: 21px;
  font-weight: 850;
}

.evaluation-summary-header button {
  border: none;
  background: transparent;
  color: #6fa04f;
  font-family: inherit;
  font-size: 16px;
  font-weight: 800;
  cursor: pointer;
}

.evaluation-summary-header button:hover {
  color: #527e3e;
}

/* Lista resumen */

.evaluation-summary-list {
  width: 100%;
}

.evaluation-summary-row {
  min-height: 66px;
  display: grid;
  grid-template-columns: 72px 1.15fr 1fr;
  align-items: center;
  gap: 12px;
  border-bottom: 1px dashed #eadfd3;
}

.evaluation-summary-row:last-child {
  border-bottom: none;
}

/* Imágenes del resumen */

.evaluation-summary-image-box {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  justify-self: start;
  overflow: visible;
}

.evaluation-summary-image {
  width: 86px;
  height: 86px;
  object-fit: contain;
  display: block;
}

.evaluation-summary-row h3 {
  margin: 0;
  color: #343349;
  font-size: 14.8px;
  font-weight: 800;
}

.evaluation-summary-row p {
  margin: 0;
  color: #686a75;
  font-size: 14.8px;
}

.evaluation-pill {
  width: fit-content;
  min-width: 44px;
  border-radius: 18px;
  background: #dcecc9;
  color: #5f8e47;
  font-size: 14px;
  font-weight: 850;
  padding: 7px 15px;
}

/* Columna derecha */

.evaluation-action-column {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* Bloque ¿Qué sucede ahora? */

.evaluation-next-card {
  min-height: 210px;
  background: rgba(255, 255, 255, 0.96);
  border: 1.5px solid #eadfd3;
  border-radius: 16px;
  padding: 24px 24px;
  display: flex;
  flex-direction: column;
  gap: 18px;
  box-shadow: 0 14px 32px rgba(146, 116, 78, 0.08);
}

.evaluation-next-card h2 {
  margin: 0;
  color: #343349;
  font-size: 21px;
  font-weight: 850;
  text-align: left;
}

.evaluation-next-content {
  display: grid;
  grid-template-columns: 135px 1fr;
  align-items: center;
  gap: 18px;
}

.evaluation-next-image-box {
  width: 135px;
  height: 120px;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  overflow: visible;
  transform: translateX(-34px);
}

.evaluation-next-image {
  width: 185px;
  height: 185px;
  object-fit: contain;
  display: block;
}

.evaluation-next-content p {
  margin: 0;
  color: #343349;
  font-size: 15.5px;
  line-height: 1.55;
  font-weight: 600;
}

/* Botón */

.evaluation-main-button {
  width: 100%;
  height: 52px;
  border: none;
  border-radius: 13px;
  background: linear-gradient(135deg, #8ab86c, #6fa04f);
  color: #ffffff;
  font-family: inherit;
  font-size: 20px;
  font-weight: 850;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 22px;
  cursor: pointer;
  position: relative;
  line-height: 1;
  white-space: nowrap;
  box-shadow: 0 10px 22px rgba(111, 160, 79, 0.28);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.evaluation-main-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 14px 26px rgba(111, 160, 79, 0.32);
}

.evaluation-main-button-icon {
  width: 58px;
  height: 58px;
  object-fit: contain;
  display: block;
  position: absolute;
  left: 38px;
  top: 50%;
  transform: translateY(-50%);
}

.evaluation-main-button-text {
  display: block;
  text-align: center;
  white-space: nowrap;
  transform: translateY(-1px);
}

.evaluation-main-button-space {
  display: none;
}

/* Nota segura */

.evaluation-secure-note {
  margin: 0;
  color: #85838a;
  text-align: center;
  font-size: 14px;
  font-weight: 600;
}

.evaluation-secure-note span {
  margin-right: 8px;
}

/* Footer integrado */

.evaluation-page-wrapper .app-footer {
  width: 100%;
  margin-top: 0;
}

/* Responsive */

@media (max-width: 1050px) {
  .evaluation-desktop {
    grid-template-columns: 1fr;
  }

  .evaluation-sidebar {
    /* Removed display none, handled by index.css */
  }

  .evaluation-grid-content {
    grid-template-columns: 1fr;
  }

  .evaluation-hero-card {
    grid-template-columns: 150px 1fr;
  }

  .evaluation-hero-image-box {
    width: 150px;
    height: 110px;
  }

  .evaluation-hero-image {
    width: 210px;
    height: 210px;
  }
}

@media (max-width: 760px) {
  .evaluation-desktop {
    width: 100%;
    margin-top: 0;
    border-radius: 0;
    border-left: none;
    border-right: none;
  }

  .evaluation-main-panel {
    padding: 26px 18px;
  }

  .evaluation-title-row h1 {
    font-size: 23px;
  }

  .evaluation-hero-card {
    grid-template-columns: 98px 1fr;
    padding: 18px;
  }

  .evaluation-hero-image-box {
    width: 98px;
    height: 86px;
  }

  .evaluation-hero-image {
    width: 145px;
    height: 145px;
  }

  .evaluation-summary-row {
    grid-template-columns: 64px 1fr;
    gap: 10px;
    padding: 12px 0;
  }

  .evaluation-summary-row p,
  .evaluation-pill {
    grid-column: 2;
  }

  .evaluation-summary-image-box {
    width: 58px;
    height: 58px;
  }

  .evaluation-summary-image {
    width: 76px;
    height: 76px;
  }

  .evaluation-next-card {
    text-align: center;
  }

  .evaluation-next-card h2 {
    text-align: center;
  }

  .evaluation-next-content {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .evaluation-next-image-box {
    margin: 0 auto;
    width: 160px;
    height: 130px;
    justify-content: center;
    transform: none;
  }

  .evaluation-next-image {
    width: 210px;
    height: 210px;
  }
}

@media (max-width: 430px) {
  .evaluation-main-panel {
    padding: 22px 14px;
  }

  .evaluation-title-row {
    grid-template-columns: 1fr 38px;
  }

  .evaluation-title-row h1 {
    font-size: 21px;
  }

  .evaluation-hero-card {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .evaluation-hero-image-box {
    width: 100%;
    height: 110px;
  }

  .evaluation-hero-image {
    width: 170px;
    height: 170px;
  }

  .evaluation-summary-card {
    padding: 20px 18px 10px;
  }

  .evaluation-summary-header {
    align-items: flex-start;
    gap: 10px;
  }

  .evaluation-summary-header h2 {
    font-size: 18px;
  }

  .evaluation-summary-image {
    width: 70px;
    height: 70px;
  }

  .evaluation-main-button {
    height: 50px;
    font-size: 18px;
  }

  .evaluation-main-button-icon {
    width: 52px;
    height: 52px;
    left: 26px;
  }
}
