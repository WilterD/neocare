<file path="frontend/src/pages/UserHome/UserHome.css">
* {
  box-sizing: border-box;
}

.user-home-page-wrapper {
  width: 100%;
  min-height: 100vh;
  background: #fff6ec;
  font-family: "Segoe UI", Arial, sans-serif;
  color: #343349;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Contenedor principal igual a Evaluation */

.user-home-desktop {
  width: calc(100% - 44px);
  max-width: 1180px;
  min-height: 700px;
  margin-top: 10px;
  margin-bottom: 28px;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
  border: 1px solid #eee7df;
  border-radius: 8px;
  display: grid;
  grid-template-columns: 185px 1fr;
  overflow: hidden;
  box-shadow: 0 16px 48px rgba(146, 116, 78, 0.12);
}

/* Sidebar */

.user-home-sidebar {
  position: relative;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
  border-right: 1px solid #eadfd3;
  padding: 42px 14px 24px;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.user-home-sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.user-home-sidebar-item {
  width: 100%;
  height: 50px;
  border: none;
  border-radius: 16px;
  background: transparent;
  color: #343349;
  font-family: inherit;
  font-size: 15px;
  font-weight: 700;
  display: grid;
  grid-template-columns: 46px 1fr;
  align-items: center;
  text-align: left;
  padding: 0 12px;
  cursor: pointer;
  text-decoration: none;
  transition: color 0.2s ease, background 0.2s ease;
}

.user-home-sidebar-icon-box {
  width: 42px;
  height: 42px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.user-home-sidebar-icon {
  width: 48px;
  height: 48px;
  object-fit: contain;
  display: block;
  transition: transform 0.2s ease;
}

.user-home-sidebar-item:hover {
  color: #6fa04f;
  background: transparent;
}

.user-home-sidebar-item:hover .user-home-sidebar-icon {
  transform: scale(1.06);
}

.user-home-sidebar-item.active {
  background: rgba(213, 230, 196, 0.45);
  border: 1.5px solid rgba(111, 160, 79, 0.38);
  color: #6fa04f;
  font-weight: 800;
}

.user-home-sidebar-item.active .user-home-sidebar-icon {
  transform: scale(1.08);
}

/* Panel principal */

.user-home-main-panel {
  padding: 18px 28px 28px;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
  overflow: hidden;
}

/* Hero principal */

.user-home-hero-card {
  width: 100%;
  min-height: 246px;
  border: 1.5px solid #eadfd3;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.96);
  display: grid;
  grid-template-columns: 1fr 390px;
  align-items: center;
  gap: 16px;
  padding: 28px 34px;
  overflow: hidden;
  position: relative;
  box-shadow: 0 14px 32px rgba(146, 116, 78, 0.08);
}

.user-home-hero-text h2 {
  margin: 0 0 12px;
  color: #343349;
  font-size: 32px;
  font-weight: 850;
  letter-spacing: -0.6px;
  line-height: 1.12;
}

.user-home-hero-text h2 span {
  color: #4f982a;
}

.user-home-hero-text h3 {
  margin: 0 0 14px;
  color: #32761c;
  font-size: 16px;
  font-weight: 850;
}

.user-home-hero-text p {
  margin: 0 0 22px;
  color: #343349;
  font-size: 15.5px;
  line-height: 1.55;
  max-width: 560px;
}

.user-home-hero-actions {
  display: flex;
  align-items: center;
  gap: 16px;
}

.user-home-main-button,
.user-home-secondary-button {
  height: 52px;
  border-radius: 13px;
  font-family: inherit;
  font-size: 15px;
  font-weight: 850;
  cursor: pointer;
  line-height: 1;
  white-space: nowrap;
}

.user-home-main-button {
  border: none;
  background: linear-gradient(135deg, #8ab86c, #6fa04f);
  color: #ffffff;
  padding: 0 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  box-shadow: 0 10px 22px rgba(111, 160, 79, 0.28);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.user-home-main-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 14px 26px rgba(111, 160, 79, 0.32);
}

.user-home-main-button-icon {
  width: 42px;
  height: 42px;
  object-fit: contain;
  display: block;
}

.user-home-secondary-button {
  border: 1.5px solid #6fa04f;
  background: #ffffff;
  color: #343349;
  padding: 0 24px;
}

.user-home-hero-image-box {
  width: 390px;
  height: 230px;
  display: flex;
  justify-content: center;
  align-items: center;
  justify-self: end;
  overflow: visible;
}

.user-home-hero-image {
  width: 420px;
  height: 420px;
  object-fit: contain;
  display: block;
}

/* Seguimiento actual horizontal */

.user-home-current-card {
  width: 100%;
  margin-top: 20px;
  background: rgba(255, 255, 255, 0.96);
  border: 1.5px solid #eadfd3;
  border-radius: 16px;
  box-shadow: 0 14px 32px rgba(146, 116, 78, 0.08);
  padding: 18px 16px;
  display: grid;
  grid-template-columns: 250px minmax(0, 1fr) 118px;
  column-gap: 16px;
  row-gap: 12px;
  align-items: center;
  overflow: visible;
}

/* Bloque izquierdo */

.user-home-current-title {
  grid-column: 1;
  grid-row: 1 / 3;
  display: grid;
  grid-template-columns: 42px 1fr;
  gap: 12px;
  align-items: start;
  align-self: stretch;
  border-right: 1px solid #eadfd3;
  padding-right: 18px;
}

.user-home-current-title-icon {
  width: 38px;
  height: 38px;
  border: 1.5px solid #9fc67a;
  border-radius: 8px;
  color: #6fa04f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  font-weight: 850;
  flex-shrink: 0;
}

.user-home-current-title h2 {
  margin: 0 0 8px;
  color: #343349;
  font-size: 18px;
  font-weight: 850;
  line-height: 1.2;
}

.user-home-current-title p {
  margin: 0;
  color: #686a75;
  font-size: 13px;
  line-height: 1.45;
  font-weight: 500;
}

/* Datos centrales con títulos estables */

.user-home-current-info {
  grid-column: 2;
  grid-row: 1;
  width: 100%;
  min-width: 0;
  display: grid;
  grid-template-columns: 1fr 1fr 1.25fr 1.45fr;
  align-items: center;
}

.user-home-current-info article {
  min-width: 0;
  height: 62px;
  display: grid;
  grid-template-columns: 38px 1fr;
  align-items: center;
  column-gap: 8px;
  padding: 0 16px;
  position: relative;
}

.user-home-current-info article::after {
  content: "";
  position: absolute;
  right: -12px;
  top: 8px;
  width: 1px;
  height: 46px;
  background: #eadfd3;
}

.user-home-current-info article:last-child::after {
  display: none;
}

.user-home-current-info img {
  width: 36px;
  height: 36px;
  object-fit: contain;
  display: block;
  flex-shrink: 0;
}

.user-home-current-info article div {
  min-width: 0;
  height: 46px;
  display: grid;
  grid-template-rows: 18px 28px;
  align-items: start;
}

.user-home-current-info span {
  display: block;
  height: 18px;
  margin: 0;
  color: #686a75;
  font-size: 11.4px;
  font-weight: 650;
  line-height: 1.05;
}

.user-home-current-info strong {
  display: block;
  margin: 8px 0 0;
  color: #343349;
  font-size: 12.5px;
  font-weight: 850;
  line-height: 1.12;
  white-space: normal;
  word-break: normal;
}

/* Bebé */

.user-home-current-info article:nth-child(1) {
  padding-left: 0;
}

/* Edad */

.user-home-current-info article:nth-child(2) {
  padding-left: 18px;
}

/* Última evaluación */

.user-home-current-info article:nth-child(3) {
  padding-left: 20px;
}

/* Nivel de seguimiento */

.user-home-current-info article:nth-child(4) {
  padding-left: 20px;
  padding-right: 0;
}

.user-home-current-info article:nth-child(3) span {
  max-width: 82px;
}

.user-home-current-info article:nth-child(4) span {
  max-width: 92px;
}

/* Pastilla de riesgo */

.user-home-risk-pill {
  width: fit-content;
  max-width: 100%;
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  background: #fff1ce;
  color: #e98a00 !important;
  font-size: 11.4px !important;
  font-weight: 850 !important;
  padding: 5px 9px;
  white-space: nowrap;
  line-height: 1 !important;
}

/* Recomendación debajo de los datos */

.user-home-current-recommendation {
  grid-column: 2;
  grid-row: 2;
  background: #fff8ea;
  border: 1.5px solid #f3dfb9;
  border-radius: 11px;
  padding: 11px 14px;
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
}

.user-home-current-recommendation span {
  color: #f4a000;
  font-size: 18px;
  flex-shrink: 0;
}

.user-home-current-recommendation p {
  margin: 0;
  color: #686a75;
  font-size: 13px;
  line-height: 1.35;
}

.user-home-current-recommendation strong {
  color: #b97800;
  font-weight: 850;
}

/* Botón derecho */

.user-home-result-button {
  grid-column: 3;
  grid-row: 1 / 3;
  justify-self: end;
  align-self: center;
  width: 110px;
  height: 64px;
  border: 1.5px solid #8ab86c;
  border-radius: 11px;
  background: #ffffff;
  color: #343349;
  font-family: inherit;
  font-size: 12px;
  font-weight: 850;
  line-height: 1.25;
  cursor: pointer;
  padding: 0 10px;
}

.user-home-result-button:hover {
  border-color: #6fa04f;
  color: #6fa04f;
}

/* Próximas acciones */

.user-home-actions-card {
  margin-top: 20px;
  background: rgba(255, 255, 255, 0.96);
  border: 1.5px solid #eadfd3;
  border-radius: 22px;
  padding: 22px 24px 24px;
  box-shadow: 0 18px 45px rgba(146, 116, 78, 0.14);
}

.user-home-actions-header h2 {
  margin: 0 0 6px;
  color: #3d7d24;
  font-size: 21px;
  font-weight: 850;
}

.user-home-actions-header p {
  margin: 0 0 18px;
  color: #686a75;
  font-size: 14.8px;
}

.user-home-actions-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}

.user-home-suggestion-card {
  min-height: 138px;
  border: 1.5px solid #eadfd3;
  border-radius: 16px;
  background: #ffffff;
  padding: 18px 18px;
  box-shadow: 0 10px 24px rgba(146, 116, 78, 0.06);
}

.user-home-suggestion-card h3 {
  margin: 0 0 10px;
  color: #343349;
  font-size: 15px;
  font-weight: 850;
  line-height: 1.35;
}

.user-home-suggestion-card p {
  margin: 0;
  color: #686a75;
  font-size: 13.8px;
  line-height: 1.55;
}

/* Recordatorio */

.user-home-reminder-card {
  margin-top: 20px;
  background: #f8f7e7;
  border: 1.5px solid #eadfd3;
  border-radius: 18px;
  padding: 22px 26px;
  box-shadow: 0 14px 32px rgba(146, 116, 78, 0.08);
}

.user-home-reminder-card h2 {
  margin: 0 0 8px;
  color: #4f982a;
  font-size: 21px;
  font-weight: 850;
}

.user-home-reminder-card p {
  margin: 0;
  color: #343349;
  font-size: 14.8px;
  line-height: 1.55;
  font-weight: 600;
}

/* Footer integrado */

.user-home-page-wrapper .app-footer {
  width: 100%;
  margin-top: 0;
}

/* Responsive */

@media (max-width: 1050px) {
  .user-home-desktop {
    grid-template-columns: 1fr;
  }

  .user-home-sidebar {
    display: none;
  }

  .user-home-hero-card {
    grid-template-columns: 1fr;
  }

  .user-home-hero-image-box {
    width: 150px;
    height: 110px;
    justify-self: center;
  }

  .user-home-hero-image {
    width: 210px;
    height: 210px;
  }

  .user-home-current-card {
    grid-template-columns: 1fr;
    padding: 22px;
  }

  .user-home-current-title {
    grid-column: 1;
    grid-row: auto;
    border-right: none;
    border-bottom: 1px solid #eadfd3;
    padding-right: 0;
    padding-bottom: 16px;
  }

  .user-home-current-info {
    grid-column: 1;
    grid-row: auto;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  .user-home-current-info article {
    border-bottom: 1px dashed #eadfd3;
    padding: 10px 0;
  }

  .user-home-current-info article::after {
    display: none;
  }

  .user-home-current-recommendation {
    grid-column: 1;
    grid-row: auto;
  }

  .user-home-result-button {
    grid-column: 1;
    grid-row: auto;
    justify-self: stretch;
    width: 100%;
    height: 54px;
  }

  .user-home-actions-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 760px) {
  .user-home-desktop {
    width: 100%;
    margin-top: 0;
    border-radius: 0;
    border-left: none;
    border-right: none;
  }

  .user-home-main-panel {
    padding: 18px 18px 26px;
  }

  .user-home-hero-card {
    grid-template-columns: 1fr;
    padding: 20px 18px;
  }

  .user-home-hero-text h2 {
    font-size: 25px;
  }

  .user-home-hero-actions {
    flex-direction: column;
    align-items: stretch;
  }

  .user-home-current-info {
    grid-template-columns: 1fr;
  }

  .user-home-current-info img {
    width: 42px;
    height: 42px;
  }

  .user-home-current-title h2 {
    font-size: 17px;
  }

  .user-home-actions-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 430px) {
  .user-home-main-panel {
    padding: 16px 14px 22px;
  }

  .user-home-hero-card {
    text-align: center;
  }

  .user-home-current-card {
    padding: 18px;
  }

  .user-home-current-title {
    grid-template-columns: 38px 1fr;
  }

  .user-home-current-title-icon {
    width: 34px;
    height: 34px;
    font-size: 18px;
  }

  .user-home-actions-card {
    padding: 20px 18px;
  }
}
