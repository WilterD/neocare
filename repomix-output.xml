<file path="frontend/src/pages/Profile/Profile.css">
* {
  box-sizing: border-box;
}

.profile-page-wrapper {
  width: 100%;
  min-height: 100vh;
  background: #fff6ec;
  font-family: "Segoe UI", Arial, sans-serif;
  color: #343349;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Contenedor principal igual a las demás pantallas */

.profile-desktop {
  width: calc(100% - 44px);
  max-width: 1180px;
  min-height: 700px;
  margin-top: 10px;
  margin-bottom: 28px;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
  border: 1px solid #eee7df;
  border-radius: 8px;
  display: grid;
  grid-template-columns: 185px 1fr;
  overflow: visible;
  box-shadow: 0 16px 48px rgba(146, 116, 78, 0.12);
}

/* Menú lateral */

.profile-sidebar {
  position: relative;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
  border-right: 1px solid #eadfd3;
  padding: 42px 14px 24px;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.profile-sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.profile-sidebar-item {
  width: 100%;
  height: 50px;
  border: none;
  border-radius: 16px;
  background: transparent;
  color: #343349;
  font-family: inherit;
  font-size: 15px;
  font-weight: 700;
  display: grid;
  grid-template-columns: 46px 1fr;
  align-items: center;
  text-align: left;
  padding: 0 12px;
  cursor: pointer;
  text-decoration: none;
  transition: color 0.2s ease, background 0.2s ease;
}

.profile-sidebar-icon-box {
  width: 42px;
  height: 42px;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: visible;
  background: transparent;
  border-radius: 0;
}

.profile-sidebar-icon {
  width: 48px;
  height: 48px;
  object-fit: contain;
  display: block;
  transition: transform 0.2s ease;
}

.profile-sidebar-item:hover {
  color: #6fa04f;
  background: transparent;
}

.profile-sidebar-item:hover .profile-sidebar-icon {
  transform: scale(1.06);
}

.profile-sidebar-item.active {
  background: rgba(213, 230, 196, 0.45);
  border: 1.5px solid rgba(111, 160, 79, 0.38);
  color: #6fa04f;
  font-weight: 800;
}

.profile-sidebar-item.active .profile-sidebar-icon {
  transform: scale(1.08);
}

/* Panel principal */

.profile-main-panel {
  min-width: 0;
  padding: 32px 28px 28px;
  background: linear-gradient(180deg, #fffaf2 0%, #fff3e7 100%);
}

/* Título */

.profile-title-row {
  margin-bottom: 20px;
}

.profile-title-row h1 {
  margin: 0;
  color: #343349;
  font-size: 26px;
  font-weight: 850;
  letter-spacing: -0.4px;
  line-height: 1.1;
}

.profile-title-row p {
  margin: 8px 0 0;
  color: #686a75;
  font-size: 14px;
  font-weight: 500;
  line-height: 1.4;
}

/* Resumen superior */

.profile-summary-card {
  width: 100%;
  min-height: 112px;
  border: 1.5px solid #eadfd3;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.98);
  display: grid;
  grid-template-columns: 76px 1.1fr 1px 1.05fr 1px 0.8fr 1px 1fr;
  align-items: center;
  gap: 14px;
  padding: 14px 18px;
  box-shadow: 0 10px 26px rgba(146, 116, 78, 0.08);
  margin-bottom: 18px;
}

.profile-avatar-box {
  width: 70px;
  height: 70px;
  border-radius: 0;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.profile-avatar-image {
  width: 82px;
  height: 82px;
  object-fit: contain;
  display: block;
}

.profile-summary-name {
  min-width: 0;
}

.profile-summary-name h2 {
  margin: 0 0 5px;
  color: #11142c;
  font-size: 17px;
  font-weight: 900;
  line-height: 1.15;
}

.profile-summary-name p {
  margin: 0;
  color: #686a75;
  font-size: 12px;
  font-weight: 600;
  line-height: 1.3;
}

.profile-summary-divider {
  width: 1px;
  height: 54px;
  background: #eadfd3;
}

.profile-summary-item {
  min-width: 0;
  display: grid;
  grid-template-columns: 44px minmax(0, 1fr);
  align-items: center;
  gap: 9px;
}

.profile-summary-icon {
  width: 40px;
  height: 40px;
  border-radius: 0;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.profile-summary-icon.image {
  background: transparent;
  border-radius: 0;
  overflow: visible;
}

.profile-summary-icon.image img {
  width: 52px;
  height: 52px;
  object-fit: contain;
  display: block;
}

.profile-summary-item h3 {
  margin: 0 0 4px;
  color: #11142c;
  font-size: 11px;
  font-weight: 850;
  line-height: 1.2;
}

.profile-summary-item p {
  margin: 0;
  color: #343349;
  font-size: 11.7px;
  font-weight: 600;
  line-height: 1.25;
  word-break: break-word;
}

/* Contenido principal */

.profile-content-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18px;
  align-items: stretch;
}

/* Tarjetas */

.profile-form-card {
  min-height: auto;
  border: 1.5px solid #eadfd3;
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.98);
  padding: 18px 20px;
  box-shadow: 0 8px 22px rgba(146, 116, 78, 0.08);
}

.profile-form-card.password {
  min-height: auto;
}

/* Encabezado de tarjetas */

.profile-card-heading,
.profile-form-card.password .profile-card-heading {
  display: grid;
  grid-template-columns: 38px minmax(0, 1fr);
  align-items: start;
  gap: 10px;
  margin-bottom: 16px;
}

.profile-card-icon,
.profile-card-icon.image,
.profile-form-card.password .profile-card-icon.image {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: #eef8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.profile-card-icon.image img {
  width: 42px !important;
  height: 42px !important;
  object-fit: contain;
  display: block;
}


/* TusD un poco más grande */

.profile-form-card.password .profile-card-icon.image img {
  width: 95px !important;
  height: 95px !important;
  object-fit: contain;
  display: block;
}

.profile-card-heading h2 {
  margin: 0 0 4px;
  color: #11142c;
  font-size: 15px;
  font-weight: 900;
  line-height: 1.15;
}

.profile-card-heading p {
  margin: 0;
  color: #343349;
  font-size: 11.4px;
  font-weight: 500;
  line-height: 1.35;
}

/* Formulario datos personales */

.profile-form-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 9px;
}

.profile-field {
  min-width: 0;
  display: grid;
  gap: 8px;
}

.profile-form-card:not(.password) .profile-field {
  display: grid;
  grid-template-columns: 120px minmax(0, 1fr);
  align-items: center;
  gap: 12px;
}

.profile-field span {
  color: #11142c;
  font-size: 11.5px;
  font-weight: 850;
  line-height: 1.2;
}

.profile-field input,
.profile-field select {
  width: 100%;
  height: 34px;
  border: 1.4px solid #dfe4dc;
  border-radius: 7px;
  background: #ffffff;
  color: #343349;
  font-family: inherit;
  font-size: 11.8px;
  font-weight: 500;
  padding: 0 10px;
  outline: none;
  transition: all 0.18s ease;
}

.profile-field select {
  cursor: pointer;
}

.profile-field input:focus,
.profile-field select:focus {
  border-color: #8ab86c;
  box-shadow: 0 0 0 3px rgba(111, 160, 79, 0.12);
}

/* Contraseña */

.profile-password-grid {
  display: grid;
  gap: 10px;
}

.profile-form-card.password .profile-field {
  display: grid;
  gap: 6px;
}

.profile-password-input {
  width: 100%;
  height: 34px;
  border: 1.4px solid #dfe4dc;
  border-radius: 7px;
  background: #ffffff;
  display: flex;
  align-items: center;
  overflow: hidden;
  transition: all 0.18s ease;
}

.profile-password-input:focus-within {
  border-color: #8ab86c;
  box-shadow: 0 0 0 3px rgba(111, 160, 79, 0.12);
}

.profile-password-input input {
  width: 100%;
  height: 100%;
  border: none;
  outline: none;
  background: transparent;
  color: #343349;
  font-family: inherit;
  font-size: 11.8px;
  font-weight: 500;
  padding: 0 10px;
}

.profile-password-input input::placeholder {
  color: #9a96a0;
}

.profile-password-input button {
  display: none;
}

.profile-password-note {
  margin: 10px 0 0;
  color: #686a75;
  font-size: 11px;
  font-weight: 600;
  line-height: 1.3;
}

/* Mensajes */

.profile-success-message {
  margin: 10px 0 0;
  color: #2f7f2f;
  font-size: 11.5px;
  font-weight: 750;
  line-height: 1.3;
}

.password-message {
  margin-bottom: 12px;
}

/* Botones */

.profile-button-row {
  margin-top: 16px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.profile-save-button,
.profile-cancel-button,
.profile-password-button {
  min-height: 36px;
  border-radius: 7px;
  font-family: inherit;
  font-size: 11.8px;
  font-weight: 850;
  cursor: pointer;
  transition: all 0.2s ease;
}

.profile-save-button,
.profile-password-button {
  border: none;
  background: linear-gradient(135deg, #8ab86c, #6fa04f);
  color: #ffffff;
  box-shadow: 0 8px 18px rgba(111, 160, 79, 0.2);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 0 16px;
}

.profile-save-button:hover,
.profile-password-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 24px rgba(111, 160, 79, 0.26);
}

.profile-cancel-button {
  border: 1.5px solid #aeb4c0;
  background: #ffffff;
  color: #343349;
  padding: 0 18px;
}

.profile-cancel-button:hover {
  background: #f7f7f7;
}

.profile-password-button {
  width: auto;
  margin-top: 16px;
}

/* GUARDAR y CANDADO un poco más grandes */

.profile-save-button .profile-button-icon,
.profile-password-button .profile-button-icon {
  width: 36px !important;
  height: 36px !important;
  object-fit: contain;
  display: block;
}

/* Seguridad de la información */

.profile-security-card {
  margin-top: 18px;
  border: 1.5px solid #eadfd3;
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.98);
  padding: 16px 20px;
  display: grid;
  grid-template-columns: 78px minmax(0, 1fr);
  align-items: center;
  gap: 16px;
  box-shadow: 0 8px 22px rgba(146, 116, 78, 0.08);
}

.profile-security-image-box {
  width: 70px;
  height: 70px;
  border-radius: 0;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.profile-security-image {
  width: 78px;
  height: 78px;
  object-fit: contain;
  display: block;
}

.profile-security-card h2 {
  margin: 0 0 5px;
  color: #11142c;
  font-size: 15px;
  font-weight: 900;
  line-height: 1.15;
}

.profile-security-card p {
  margin: 0;
  color: #343349;
  font-size: 11.5px;
  font-weight: 500;
  line-height: 1.35;
}

/* Footer */

.profile-page-wrapper .app-footer {
  width: 100%;
  margin-top: 0;
}

/* Responsive */

@media (max-width: 1100px) {
  .profile-desktop {
    grid-template-columns: 1fr;
  }

  .profile-sidebar {
    /* Removed display none, handled by index.css */
  }

  .profile-summary-card {
    grid-template-columns: 76px 1fr;
  }

  .profile-summary-divider {
    display: none;
  }

  .profile-summary-item {
    grid-column: 1 / -1;
  }

  .profile-content-grid {
    grid-template-columns: 1fr;
  }

  .profile-form-card:not(.password) .profile-field {
    grid-template-columns: 140px minmax(0, 1fr);
  }
}

@media (max-width: 760px) {
  .profile-desktop {
    width: 100%;
    margin-top: 0;
    margin-bottom: 0;
    border-radius: 0;
    border-left: none;
    border-right: none;
  }

  .profile-main-panel {
    padding: 24px 18px;
  }

  .profile-title-row h1 {
    font-size: 23px;
  }

  .profile-summary-card {
    grid-template-columns: 72px 1fr;
    padding: 16px;
  }

  .profile-avatar-box {
    width: 68px;
    height: 68px;
  }

  .profile-avatar-image {
    width: 78px;
    height: 78px;
  }

  .profile-form-card:not(.password) .profile-field {
    grid-template-columns: 1fr;
    gap: 6px;
  }

  .profile-security-card {
    grid-template-columns: 1fr;
    text-align: center;
    justify-items: center;
  }

  .profile-button-row {
    flex-direction: column;
    align-items: stretch;
  }

  .profile-save-button,
  .profile-cancel-button,
  .profile-password-button {
    width: 100%;
  }
}

@media (max-width: 430px) {
  .profile-main-panel {
    padding: 22px 14px;
  }

  .profile-title-row h1 {
    font-size: 21px;
  }

  .profile-summary-card,
  .profile-form-card,
  .profile-security-card {
    border-radius: 16px;
  }

  .profile-card-heading,
  .profile-form-card.password .profile-card-heading {
    grid-template-columns: 36px 1fr;
  }

  .profile-card-icon.image img {
    width: 40px !important;
    height: 40px !important;
  }

  .profile-form-card.password .profile-card-icon.image img {
    width: 48px !important;
    height: 48px !important;
  }

  .profile-summary-icon.image img {
    width: 48px;
    height: 48px;
  }

  .profile-save-button .profile-button-icon,
  .profile-password-button .profile-button-icon {
    width: 24px !important;
    height: 24px !important;
  }
}
</file>

