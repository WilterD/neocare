.edu-seg-hero-label {
  color: #6fa04f;
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.edu-seg-hero h1 {
  margin: 4px 0 8px;
  color: #343349;
  font-size: 24px;
  font-weight: 850;
  letter-spacing: -0.5px;
}

.edu-seg-hero p {
  margin: 0 0 10px;
  color: #343349;
  font-size: 13px;
  line-height: 1.45;
}

.edu-seg-hero-tags {
  display: flex;
  flex-wrap: wrap;
