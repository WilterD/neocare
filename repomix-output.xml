      tipoParto: b.tipo_parto,
      complicacionesAlNacer: b.complicaciones_al_nacer,
      especificacionComplicaciones: b.especificacion_complicaciones,
      hospitalizacionNeonatal: b.hospitalizacion_neonatal,
