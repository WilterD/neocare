  z-index: 3;
}

.hero-floating-heart {
  color: #d9c0ec;
  font-size: 30px;
  font-weight: 800;
}

.heart-a {
  right: 70px;
  top: 34px;
  color: #c9ddb6;
}

.heart-b {
  right: 34px;
  top: 94px;
  color: #d9c0ec;
}

.hero-floating-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #c9ddb6;
}

.dot-a {
  left: 48px;
  top: 64px;
}

.dot-b {
  right: 135px;
  top: 24px;
}

/* Grid de servicios */

.services-grid {
  width: 100%;
  margin-top: 22px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18px;
  align-items: stretch;
}

.service-card {
  background: rgba(255, 255, 255, 0.94);
  border: 1.5px solid #eadfd3;
  border-radius: 16px;
  box-shadow: 0 12px 30px rgba(146, 116, 78, 0.08);
  display: grid;
  grid-template-columns: 86px 1fr;
  align-items: center;
  gap: 18px;
  padding: 22px 22px;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.service-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 16px 34px rgba(146, 116, 78, 0.12);
}

.service-image-box {
  width: 86px;
  height: 100%;
  min-height: 120px;
  display: flex;
  align-items: center;
  justify-content: center;
  align-self: stretch;
  overflow: visible;
  padding: 0;
  margin: 0;
}

.service-card-image {
  width: 86px;
  height: 86px;
  object-fit: contain;
  display: block;
  transform: scale(1.45);
  transform-origin: center;
}

.service-card-text {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
  align-self: flex-start;
  padding-top: 0;
  margin-top: 0;
}

.service-card-text h2 {
  margin: 0 0 8px;
  color: #101935;
  font-size: 17px;
  font-weight: 900;
  line-height: 1.15;
}

.service-card-text p {
  margin: 0;
  color: #50566d;
  font-size: 14.5px;
  line-height: 1.45;
  font-weight: 500;
}

/* Barra inferior */

.services-trust-bar {
  width: 100%;
  margin-top: 22px;
  background: rgba(255, 255, 255, 0.94);
  border: 1.5px solid #eadfd3;
  border-radius: 16px;
  box-shadow: 0 12px 30px rgba(146, 116, 78, 0.08);
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  padding: 22px 28px;
  overflow: visible;
}

.services-trust-bar article {
  display: grid;
  grid-template-columns: 42px 1fr;
  align-items: center;
  gap: 4px;
  overflow: visible;
}

.services-trust-bar article > span {
  color: #6fa04f;
  font-size: 34px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Imágenes de la barra inferior */

.services-trust-icon {
  width: 54px;
  height: 54px;
  object-fit: contain;
  display: block;
  justify-self: center;
  align-self: center;
  max-width: 54px;
  max-height: 54px;
  transform: translateX(3px) scale(2.1);
  transform-origin: center;
  pointer-events: none;
}

.services-trust-bar h3 {
  margin: 0 0 5px;
  color: #263b2e;
  font-size: 15.5px;
  font-weight: 800;
}

.services-trust-bar p {
  margin: 0;
  color: #697083;
  font-size: 13.8px;
  line-height: 1.4;
}

/* Responsive */

@media (max-width: 1100px) {
  .services-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .services-hero {
    height: auto;
    min-height: 360px;
    grid-template-columns: 1fr;
    padding: 28px 34px;
    text-align: center;
  }

  .services-hero-text p {
    margin: 0 auto;
  }

  .services-hero-actions,
  .services-safe-note {
    justify-content: center;
  }

  .services-hero-image-area {
    height: 210px;
  }

  .services-hero-image {
    width: 255px;
  }
}

@media (max-width: 760px) {
  .services-page {
    width: calc(100% - 28px);
    margin-top: 12px;
  }

  .services-hero {
    height: auto;
    min-height: auto;
    padding: 28px 22px;
  }

  .services-hero-text h1 {
    font-size: 32px;
  }

  .services-hero-text p {
    font-size: 16px;
  }

  .services-hero-actions {
    flex-direction: column;
    width: 100%;
  }

  .services-primary-btn,
  .services-secondary-btn {
    width: 100%;
  }

  .services-primary-btn {
    min-width: unset;
