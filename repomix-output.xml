  .about-guide-card {
    grid-template-columns: repeat(2, 1fr);
  }

  .about-guide-item {
    border-bottom: 1px solid #eadfd3;
  }

  .about-guide-item:nth-child(2n) {
    border-right: none;
  }

  .about-team-section {
    max-width: 760px;
  }

  .about-team-list {
    text-align: left;
  }
}

@media (max-width: 760px) {
  .about-page {
    width: 100%;
    margin-top: 0;
    border-radius: 0;
    border-left: none;
    border-right: none;
