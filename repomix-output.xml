<file path="frontend/src/components/Header2/Header2.css">
.header2 {
  width: 100%;
  height: 62px;
  background: #ffffff;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 3px 12px rgba(146, 116, 78, 0.07);
  position: sticky;
  top: 0;
  z-index: 999;
  font-family: "Segoe UI", Arial, sans-serif;
  color: #20253a;
}

.header2-container {
  width: 100%;
  max-width: 1180px;
  height: 100%;
  display: grid;
  grid-template-columns: 300px 1fr 270px;
  align-items: center;
  padding: 0 22px;
  gap: 22px;
  transform: translateY(-6px);
}

/* Logo izquierdo y burger */

.header2-burger-btn {
  display: none;
  background: transparent;
  border: none;
  padding: 8px;
  margin-right: 2px;
  cursor: pointer;
  color: #6fa04f;
}

.burger-icon {
  width: 32px;
  height: 32px;
}

.header2-brand {
  display: flex;
  align-items: center;
  gap: 0;
  height: 100%;
  text-decoration: none;
}

.header2-logo {
  width: 92px;
  height: 92px;
  object-fit: contain;
  display: block;
  flex-shrink: 0;
}

.header2-brand span {
  color: #3f3a37;
  font-size: 23px;
  font-weight: 850;
  letter-spacing: -0.5px;
  margin-left: -18px;
  line-height: 1;
}

/* Usuario derecho */

.header2-user-area {
  grid-column: 3;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 14px;
  height: 100%;
  margin-right: -18px;
}

.header2-user-button {
  border: none;
  background: transparent;
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  padding: 0;
  font-family: inherit;
  color: #3f3a37;
  height: 100%;
  overflow: visible;
  transform: translateX(-50px);
}

.header2-avatar {
  width: 46px;
  height: 46px;
  border-radius: 50%;
  object-fit: cover;
  display: block;
  flex-shrink: 0;
  transform: scale(1.75);
  transform-origin: center;
}

.header2-user-button span {
  color: #5d5752;
  font-size: 15px;
  font-weight: 750;
  line-height: 1;
}

/* Botón cierre */

/* Contenedor de Ajustes */
.header2-settings-wrapper {
  position: relative;
  display: inline-block;
  transform: translateX(38px);
}

.header2-settings-button {
  width: 46px;
  height: 46px;
  border: none;
  background: transparent;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-shadow: none;
  overflow: visible;
  transition: transform 0.2s ease;
}

.header2-settings-button:hover {
  transform: translateY(-1px);
}

.header2-settings-icon {
  width: 46px;
  height: 46px;
  object-fit: contain;
  display: block;
  flex-shrink: 0;
  transform: scale(2.8);
  transform-origin: center;
}

/* Dropdown de Ajustes */
.header2-dropdown {
  position: absolute;
  top: 55px;
  right: -20px;
  background: #ffffff;
  border-radius: 8px;
  box-shadow: 0 4px 18px rgba(0, 0, 0, 0.12);
  border: 1px solid rgba(146, 116, 78, 0.1);
  padding: 6px;
  min-width: 150px;
  z-index: 100;
  display: flex;
  flex-direction: column;
}

.header2-dropdown::before {
  content: "";
  position: absolute;
  top: -6px;
  right: 32px;
  width: 10px;
  height: 10px;
  background: #ffffff;
  border-left: 1px solid rgba(146, 116, 78, 0.1);
