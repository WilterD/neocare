                    </span>

                    <div>
                      <h3>{module.title}</h3>
                      <p>{module.description}</p>
                    </div>

                    <span className="education-arrow">›</span>
                  </button>
                ))}
              </div>
            </aside>
          </section>

          <section className="education-doubts-card">
            <div className="education-doubts-icon">
              <img
                src={dudaImage}
