<file path="frontend/src/pages/Contact/Contact.css">
* {
  box-sizing: border-box;
}

.contact-page-wrapper {
  width: 100%;
  min-height: 100vh;
  background: #fff6ec;
  font-family: "Segoe UI", Arial, sans-serif;
  color: #343349;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.contact-page {
  width: calc(100% - 44px);
  max-width: 1180px;
  margin-top: 10px;
  margin-bottom: 28px;
  padding: 38px 34px 34px;
  background: transparent;
  border: none;
  border-radius: 0;
  box-shadow: none;
}

/* Hero */

.contact-hero {
  max-width: 760px;
  margin: 0 auto 34px;
  text-align: center;
}

.contact-eyebrow {
  margin: 0 0 18px;
  color: #3d7d24;
  font-size: 14px;
  font-weight: 850;
  letter-spacing: 1px;
}

.contact-hero h1 {
  margin: 0;
  color: #4b3326;
  font-size: 42px;
  font-weight: 850;
  line-height: 1.15;
  letter-spacing: -1.2px;
}

.contact-heart {
  margin: 18px 0;
  color: #f0a59a;
  font-size: 24px;
  line-height: 1;
}

.contact-subtitle {
  max-width: 640px;
  margin: 0 auto 22px;
  color: #343349;
  font-size: 17px;
  font-weight: 500;
  line-height: 1.65;
}

.contact-note {
  max-width: 600px;
  margin: 0 auto;
  color: #8b5b4b;
  font-size: 14px;
  font-weight: 500;
  line-height: 1.55;
}

/* Main layout */

.contact-main-grid {
  width: 100%;
  max-width: 980px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 0.95fr;
  gap: 20px;
  align-items: stretch;
}

.contact-card {
  background: rgba(255, 255, 255, 0.96);
  border: 1.5px solid #eadfd3;
  border-radius: 22px;
  box-shadow: 0 14px 32px rgba(146, 116, 78, 0.08);
}

.contact-form-card {
  padding: 24px 28px;
}

/* Bloque de información con color tipo datos personales de Register */

.contact-card.contact-info-card {
  padding: 28px;
  background: linear-gradient(180deg, #fffaf2 0%, #fff6ec 100%);
  border: 1.5px solid #eadfd3;
}

.contact-card h2 {
  margin: 0 0 10px;
  color: #2f2018;
  font-size: 24px;
  font-weight: 850;
}

.contact-card-subtitle {
  margin: 0 0 20px;
  color: #343349;
  font-size: 13.8px;
  font-weight: 500;
  line-height: 1.5;
}

/* Formulario */

.contact-form {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 11px;
}

.contact-form label {
  color: #1f1f24;
  font-size: 13.8px;
  font-weight: 750;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.contact-form label span {
  color: #d15f5f;
}

.contact-form label small {
  color: #6b6b75;
  font-size: 12.8px;
  font-weight: 500;
}

.contact-form input,
.contact-form select,
.contact-form textarea {
  width: 100%;
  border: 1.4px solid #eadfd3;
  border-radius: 9px;
  background: #fffdf9;
  color: #343349;
  font-family: inherit;
  font-size: 13.8px;
  font-weight: 500;
  outline: none;
  transition: border-color 0.25s ease, box-shadow 0.25s ease;
}

.contact-form input,
.contact-form select {
  height: 40px;
  padding: 0 13px;
}

.contact-form textarea {
  min-height: 78px;
  resize: vertical;
  padding: 12px 13px;
}

.contact-form input:focus,
.contact-form select:focus,
.contact-form textarea:focus {
  border-color: #7fac5e;
  box-shadow: 0 0 0 3px rgba(127, 172, 94, 0.15);
}

.contact-submit-button {
  height: 46px;
  margin-top: 4px;
  border: none;
  border-radius: 10px;
  background: linear-gradient(135deg, #8ab86c, #6fa04f);
  color: #ffffff;
  font-family: inherit;
  font-size: 14px;
  font-weight: 850;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 11px;
  cursor: pointer;
  box-shadow: 0 12px 24px rgba(111, 160, 79, 0.25);
  transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
}

.contact-submit-button:hover {
  transform: translateY(-4px);
  box-shadow: 0 18px 32px rgba(111, 160, 79, 0.32);
  background: linear-gradient(135deg, #94c275, #6fa04f);
}

.contact-submit-button:active {
  transform: translateY(-1px);
}

.contact-submit-icon-box {
  width: 22px;
  height: 22px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: visible;
}

.contact-submit-icon {
  width: 24px;
  height: 24px;
  object-fit: contain;
  display: block;
  transform: scale(3);
  transform-origin: center;
}

.contact-privacy-text {
  margin: 4px 0 0;
  color: #5f5b63;
  font-size: 12.8px;
  font-weight: 500;
  line-height: 1.45;
}

/* Información de contacto */

.contact-info-card h2 {
  text-align: center;
  margin-bottom: 22px;
}

.contact-info-list {
  display: flex;
  flex-direction: column;
}

.contact-info-item {
  display: grid;
  grid-template-columns: 60px 1fr;
  gap: 16px;
  padding: 18px 0;
  border-bottom: 1px solid #eadfd3;
}

.contact-info-item:first-child {
  padding-top: 0;
}

.contact-info-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

/* Círculos verdes con imágenes encima */

.contact-info-icon {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: rgba(213, 230, 196, 0.45);
  color: #6f9f61;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
  flex-shrink: 0;
}

.contact-info-icon img {
  width: 78px;
  height: 78px;
  object-fit: contain;
  display: block;
}

/* CORREO */
.contact-info-item:nth-child(1) .contact-info-icon img {
  width: 88px;
  height: 88px;
}

/* UBI */
.contact-info-item:nth-child(2) .contact-info-icon img {
  width: 96px;
  height: 96px;
}

/* FACULTAS */
.contact-info-item:nth-child(3) .contact-info-icon img {
  width: 88px;
  height: 88px;
}

.contact-info-item h3 {
  margin: 3px 0 10px;
  color: #2f2018;
  font-size: 15.5px;
  font-weight: 850;
}

.contact-info-item p {
  margin: 0 0 6px;
  color: #343349;
  font-size: 13.6px;
  font-weight: 500;
  line-height: 1.42;
}

.contact-info-item p:last-child {
  margin-bottom: 0;
}

.contact-info-item:first-child p {
  color: #4f8a49;
  font-weight: 650;
}

/* Emergencia neonatal dentro de Información de contacto */

.contact-emergency-inside {
  margin-top: 24px;
  padding: 22px;
  background: linear-gradient(135deg, #fff3f1 0%, #fff8f4 100%);
  border: 1.5px solid #f2a09a;
  border-left: 4px solid #ef7772;
  border-radius: 16px;
  display: grid;
  grid-template-columns: 54px 1fr;
  gap: 16px;
  align-items: flex-start;
}

.contact-emergency-small-icon {
  width: 46px;
  height: 46px;
  border-radius: 14px;
  background: #ffd8d5;
  border: 2.5px solid #ef7772;
  color: #c73232;
  font-size: 30px;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.contact-emergency-inside h3 {
  margin: 0 0 8px;
  color: #c71e1e;
  font-size: 18px;
  font-weight: 850;
}

.contact-emergency-inside p {
  margin: 0 0 10px;
  color: #3c2b29;
  font-size: 13.5px;
  font-weight: 500;
  line-height: 1.5;
}

.contact-emergency-inside strong {
  color: #c71e1e;
  font-size: 13.5px;
  font-weight: 850;
  line-height: 1.45;
}

/* Footer */

.contact-page-wrapper .app-footer {
  width: 100%;
  margin-top: 0;
}

/* Responsive */

@media (max-width: 1000px) {
  .contact-main-grid {
    grid-template-columns: 1fr;
    max-width: 720px;
  }

  .contact-info-card h2 {
    text-align: left;
  }
}

@media (max-width: 760px) {
  .contact-page {
    width: 100%;
    margin-top: 0;
    border-radius: 0;
    border-left: none;
    border-right: none;
    padding: 30px 18px;
  }

  .contact-hero h1 {
    font-size: 32px;
  }

  .contact-subtitle {
    font-size: 15px;
  }

  .contact-form-card,
  .contact-card.contact-info-card {
    padding: 24px 22px;
  }

  .contact-info-item {
    grid-template-columns: 58px 1fr;
    gap: 14px;
  }

  .contact-info-icon {
    width: 52px;
    height: 52px;
  }

  .contact-info-icon img {
    width: 78px;
    height: 78px;
  }

  .contact-info-item:nth-child(1) .contact-info-icon img {
    width: 88px;
    height: 88px;
  }

  .contact-info-item:nth-child(2) .contact-info-icon img {
    width: 96px;
    height: 96px;
  }

  .contact-info-item:nth-child(3) .contact-info-icon img {
    width: 88px;
    height: 88px;
  }

  .contact-emergency-inside {
    grid-template-columns: 1fr;
    text-align: center;
    padding: 22px;
  }

  .contact-emergency-small-icon {
    margin: 0 auto;
  }
}
