}

/* Global Mobile Navigation (Burger Menu Overlay) */
@media (max-width: 1050px) {
  aside[class*='-sidebar'] {
    position: fixed !important;
    top: 65px !important; /* Adjust according to header height */
    left: -100% !important;
    width: 250px !important;
    height: calc(100vh - 65px) !important;
    z-index: 1000 !important;
    background: #ffffff !important;
    box-shadow: 2px 0 10px rgba(0,0,0,0.1) !important;
    transition: transform 0.3s ease-in-out, left 0.3s ease-in-out !important;
    display: flex !important;
    flex-direction: column !important;
    padding-top: 20px !important;
    border-right: 1px solid #eadfd3 !important;
    transform: translateX(0);
  }

  /* When the sidebar is toggled open via body class */
  body.sidebar-open aside[class*='-sidebar'] {
    left: 0 !important;
    transform: translateX(0) !important;
  }

  /* Background overlay when menu is open */
  body.sidebar-open::after {
    content: '';
    position: fixed !important;
    top: 65px !important;
    left: 0 !important;
    width: 100vw !important;
    height: calc(100vh - 65px) !important;
    background: rgba(0, 0, 0, 0.5) !important;
    z-index: 998 !important;
  }

  /* Reset layout constraints added previously for the bottom bar */
  section[class*='-desktop'] {
    margin-bottom: 0 !important;
  }
}
